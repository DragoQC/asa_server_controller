@inject asa_server_controller.Services.RemoteServerConfigService RemoteServerConfigService

@if (IsOpen)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/55 p-3 backdrop-blur-sm sm:p-6"
         @onclick="HandleCloseAsync">
        <div
            class="flex max-h-[92vh] w-full max-w-5xl flex-col overflow-hidden rounded-[1.8rem] border border-fuchsia-400/15 bg-[#05070d]/94 shadow-[0_0_80px_rgba(168,85,247,0.18)] backdrop-blur-xl"
            @onclick:stopPropagation="true">
            <div class="relative shrink-0 border-b border-white/10 px-5 py-5 pr-20 sm:px-6">
                <div>
                    <div class="flex flex-wrap items-center gap-3">
                        <p class="text-xs font-semibold uppercase tracking-[0.45em] text-fuchsia-300">Server config</p>
                        <span class="rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100">
                            Node config
                        </span>
                    </div>
                    <h2 class="mt-3 text-3xl font-semibold text-white">Edit server config</h2>
                    <p class="mt-3 text-sm leading-6 text-neutral-300">
                        Editing <span class="font-semibold text-white">@ServerTitle</span>. This mirrors the fields the node currently accepts through <code class="rounded bg-white/10 px-2 py-1 text-neutral-100">/api/admin/server-config</code>.
                    </p>
                </div>

                <button type="button" @onclick="HandleCloseAsync"
                    class="absolute right-5 top-5 inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/5 text-lg text-neutral-200 transition hover:bg-white/10 sm:right-6">
                    &#10005;
                </button>
            </div>

            <div class="min-h-0 flex-1 overflow-y-auto p-5 sm:p-6">
                <div class="space-y-5">
                    @if (!string.IsNullOrWhiteSpace(_statusMessage))
                    {
                        <div class="@StatusMessageClass">
                            @_statusMessage
                        </div>
                    }

                    @if (_isLoading)
                    {
                        <div class="rounded-[1.6rem] border border-fuchsia-400/15 bg-black/25 p-6 text-sm text-neutral-300 shadow-[0_0_30px_rgba(192,132,252,0.14)] backdrop-blur-xl">
                            Loading remote config...
                        </div>
                    }
                    else if (!_hasLoadedConfig)
                    {
                        <div class="rounded-[1.6rem] border border-red-300/20 bg-red-400/10 p-6 text-sm text-red-100 shadow-[0_0_30px_rgba(248,113,113,0.14)] backdrop-blur-xl">
                            <p class="text-[0.7rem] uppercase tracking-[0.3em] text-red-200/85">Remote config unavailable</p>
                            <p class="mt-3 text-base font-semibold text-white">Could not load the remote server config.</p>
                            <p class="mt-2 leading-6 text-red-100/90">The remote server may be unreachable, not fully installed, or returned an invalid response. Try again when the node is reachable.</p>
                        </div>
                    }
                    else
                    {
                        <section class="rounded-[1.6rem] border border-white/10 bg-white/5 p-6">
                            <div class="mb-5">
                                <h3 class="text-2xl font-semibold text-white">Core values</h3>
                                <p class="mt-2 text-sm text-neutral-400">Main startup values currently exposed by the remote node API.</p>
                            </div>

                            <div class="grid gap-4 md:grid-cols-2">
                                <TextHelpField Label="Map name"
                                               @bind-Value="_configMapName"
                                               Hint="Default: TheIsland_WP"
                                               OnHelpClick="@(() => OpenHelpDialog("Map name", "Selects the ASA map the node boots. Example: TheIsland_WP."))" />
                                <TextHelpField Label="Server name"
                                               @bind-Value="_configServerName"
                                               OnHelpClick="@(() => OpenHelpDialog("Server name", "This is the public server name players see in-game and in listings."))" />
                                <TextHelpField Label="Max players"
                                               @bind-Value="_configMaxPlayers"
                                               Hint="Allowed range on the node is 1 to 200."
                                               inputmode="numeric"
                                               OnHelpClick="@(() => OpenHelpDialog("Max players", "Sets the player cap the server advertises and allows."))" />
                                <TextHelpField Label="Game port"
                                               @bind-Value="_configGamePort"
                                               Hint="Allowed range on the node is 1 to 65535."
                                               inputmode="numeric"
                                               OnHelpClick="@(() => OpenHelpDialog("Game port", "Main gameplay connection port used by ASA clients."))" />
                            </div>
                        </section>

                        <section class="rounded-[1.6rem] border border-white/10 bg-white/5 p-6">
                            <div class="mb-5">
                                <h3 class="text-2xl font-semibold text-white">Mods and cluster</h3>
                                <p class="mt-2 text-sm text-neutral-400">Comma-separated mod IDs plus optional cluster ID passed to the node startup config.</p>
                            </div>

                            <div class="grid gap-4 md:grid-cols-2">
                                <div class="md:col-span-2">
                                    <TextAreaHelpField Label="Mod IDs"
                                                       @bind-Value="_configModIds"
                                                       Hint="Example: 12345,67890"
                                                       OnHelpClick="@(() => OpenHelpDialog("Mod IDs", "Comma-separated CurseForge mod IDs to load on server start. Leave empty to start without mods."))" />
                                </div>
                                <TextHelpField Label="Cluster ID"
                                               @bind-Value="_configClusterId"
                                               Hint="Leave empty if this server is not part of a cluster."
                                               OnHelpClick="@(() => OpenHelpDialog("Cluster ID", "Shared identifier used by clustered servers so they can transfer between each other."))" />
                            </div>
                        </section>

                        <section class="rounded-[1.6rem] border border-fuchsia-400/15 bg-fuchsia-400/5 p-5 text-sm leading-6 text-neutral-300">
                            <p class="text-[0.7rem] uppercase tracking-[0.3em] text-fuchsia-200/85">Read-only extras</p>
                            <p class="mt-3">Query port: <span class="font-semibold text-white">@_configQueryPort</span></p>
                            <p class="mt-1">RCON port: <span class="font-semibold text-white">@_configRconPort</span></p>
                            <p class="mt-1">Cluster dir: <span class="font-semibold text-white">@_configClusterDir</span></p>
                            <p class="mt-1">Extra args: <span class="font-semibold text-white">@_configCustomExtraArgs</span></p>
                            <p class="mt-3 text-xs text-neutral-400">Those values are returned by the node, but the current node PATCH endpoint does not accept edits for them from this manager app yet.</p>
                        </section>

                        <div class="flex justify-end gap-3 pt-2">
                            <button type="button" @onclick="HandleCloseAsync"
                                class="inline-flex rounded-full border border-white/10 bg-white/5 px-5 py-2.5 text-sm font-medium text-neutral-200 transition hover:bg-white/10">
                                Close
                            </button>

                            <button type="button" @onclick="SaveAsync" disabled="@_isSaving"
                                class="inline-flex rounded-full border border-fuchsia-300/30 bg-fuchsia-400/15 px-5 py-2.5 text-sm font-medium text-fuchsia-100 transition hover:bg-fuchsia-400/25 disabled:cursor-not-allowed disabled:opacity-60">
                                @(_isSaving ? "Saving..." : "Save config")
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

<InfoDialog IsOpen="@_showHelpDialog"
            Eyebrow="Server config"
            Title="@_helpDialogTitle"
            Message="@_helpDialogMessage"
            PillText="Help"
            OnClose="CloseHelpDialog" />

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public int RemoteServerId { get; set; }

    [Parameter]
    public string ServerTitle { get; set; } = "this server";

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback OnSaved { get; set; }

    private bool _isLoading;
    private bool _isSaving;
    private bool _hasLoadedConfig;
    private int _loadedRemoteServerId;
    private string? _statusMessage;
    private bool _statusIsError;
    private string? _configMapName;
    private string? _configServerName;
    private string? _configMaxPlayers;
    private string? _configGamePort;
    private string? _configModIds;
    private string? _configClusterId;
    private string _configQueryPort = "-";
    private string _configRconPort = "-";
    private string _configClusterDir = "-";
    private string _configCustomExtraArgs = "-";
    private bool _showHelpDialog;
    private string _helpDialogTitle = string.Empty;
    private string _helpDialogMessage = string.Empty;

    protected override async Task OnParametersSetAsync()
    {
        if (!IsOpen)
        {
            return;
        }

        if (_loadedRemoteServerId == RemoteServerId && (_hasLoadedConfig || _statusIsError || _isLoading))
        {
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        ResetStateForLoad();
        _loadedRemoteServerId = RemoteServerId;
        _isLoading = true;

        try
        {
            asa_server_controller.Models.Servers.RemoteServerConfigSettings config =
                await RemoteServerConfigService.LoadAsync(RemoteServerId);
            _configMapName = config.MapName;
            _configServerName = config.ServerName;
            _configMaxPlayers = config.MaxPlayers.ToString();
            _configGamePort = config.GamePort.ToString();
            _configModIds = config.ModIds;
            _configClusterId = config.ClusterId;
            _configQueryPort = config.QueryPort.ToString();
            _configRconPort = config.RconPort.ToString();
            _configClusterDir = string.IsNullOrWhiteSpace(config.ClusterDir) ? "-" : config.ClusterDir;
            _configCustomExtraArgs = string.IsNullOrWhiteSpace(config.CustomExtraArgs) ? "-" : config.CustomExtraArgs;
            _hasLoadedConfig = true;
        }
        catch (Exception exception)
        {
            _statusMessage = string.IsNullOrWhiteSpace(exception.Message)
                ? "Remote server config could not be loaded."
                : exception.Message;
            _statusIsError = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        _statusMessage = null;
        _statusIsError = false;

        if (!_hasLoadedConfig)
        {
            _statusMessage = "Remote server config is unavailable. Load it successfully before saving.";
            _statusIsError = true;
            return;
        }

        if (!TryParseRequiredInt(_configMaxPlayers, "Max players", out int maxPlayers) ||
            !TryParseRequiredInt(_configGamePort, "Game port", out int gamePort))
        {
            return;
        }

        _isSaving = true;

        try
        {
            await RemoteServerConfigService.SaveAsync(
                RemoteServerId,
                _configServerName ?? string.Empty,
                _configMapName ?? string.Empty,
                maxPlayers,
                gamePort,
                _configModIds ?? string.Empty,
                _configClusterId ?? string.Empty);

            await OnClose.InvokeAsync();
            await OnSaved.InvokeAsync();
            ResetComponentState();
        }
        catch (Exception exception)
        {
            _statusMessage = string.IsNullOrWhiteSpace(exception.Message)
                ? "Remote server config could not be saved."
                : exception.Message;
            _statusIsError = true;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private Task HandleCloseAsync()
    {
        if (_isSaving)
        {
            return Task.CompletedTask;
        }

        ResetComponentState();
        return OnClose.InvokeAsync();
    }

    private bool TryParseRequiredInt(string? value, string fieldName, out int parsedValue)
    {
        if (!int.TryParse(value?.Trim(), out parsedValue) || parsedValue <= 0)
        {
            _statusMessage = $"{fieldName} must be a valid positive number.";
            _statusIsError = true;
            return false;
        }

        return true;
    }

    private void OpenHelpDialog(string title, string message)
    {
        _helpDialogTitle = title;
        _helpDialogMessage = message;
        _showHelpDialog = true;
    }

    private Task CloseHelpDialog()
    {
        _showHelpDialog = false;
        return Task.CompletedTask;
    }

    private void ResetStateForLoad()
    {
        _hasLoadedConfig = false;
        _statusMessage = null;
        _statusIsError = false;
        _configMapName = null;
        _configServerName = null;
        _configMaxPlayers = null;
        _configGamePort = null;
        _configModIds = null;
        _configClusterId = null;
        _configQueryPort = "-";
        _configRconPort = "-";
        _configClusterDir = "-";
        _configCustomExtraArgs = "-";
    }

    private void ResetComponentState()
    {
        _isLoading = false;
        _isSaving = false;
        _loadedRemoteServerId = 0;
        _showHelpDialog = false;
        _helpDialogTitle = string.Empty;
        _helpDialogMessage = string.Empty;
        ResetStateForLoad();
    }

    private string StatusMessageClass =>
        _statusIsError
            ? "rounded-2xl border border-red-300/20 bg-red-400/10 px-5 py-4 text-sm text-red-100"
            : "rounded-2xl border border-emerald-300/20 bg-emerald-400/10 px-5 py-4 text-sm text-emerald-100";
}
