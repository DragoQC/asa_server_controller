<div>
    <div class="mb-2 flex items-center gap-2">
        <label class="block text-sm font-medium text-neutral-300">@Label</label>

        <button type="button"
                @onclick="OnHelpClick"
                class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 text-[0.7rem] font-semibold text-fuchsia-100 transition hover:bg-fuchsia-400/20"
                aria-label="@HelpButtonLabel">
            ?
        </button>
    </div>

    @if (IsTextArea)
    {
        <textarea value="@Value"
                  @oninput="OnTextChanged"
                  class="min-h-28 w-full rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-white outline-none"
                  @attributes="AdditionalAttributes"></textarea>
    }
    else
    {
        <input value="@Value"
               @oninput="OnTextChanged"
               class="w-full rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-white outline-none"
               @attributes="AdditionalAttributes" />
    }

    @if (!string.IsNullOrWhiteSpace(Hint))
    {
        <p class="mt-2 text-sm text-neutral-400">@Hint</p>
    }

    @if (!string.IsNullOrWhiteSpace(Error))
    {
        <p class="mt-2 text-sm text-red-300">@Error</p>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public string Label { get; set; } = "";

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public bool IsTextArea { get; set; }

    [Parameter]
    public string? Hint { get; set; }

    [Parameter]
    public string? Error { get; set; }

    [Parameter]
    public string HelpButtonLabel { get; set; } = "Open help";

    [Parameter, EditorRequired]
    public EventCallback OnHelpClick { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private Task OnTextChanged(ChangeEventArgs eventArgs)
    {
        string? nextValue = eventArgs.Value?.ToString();
        Value = nextValue;
        return ValueChanged.InvokeAsync(nextValue);
    }
}
