<div>
    <HelpDialog IsOpen="_showHelp"
                Title="@EffectiveTitle"
                HelpText="@HelpText"
                Eyebrow="@Eyebrow"
                OnClose="() => _showHelp = false">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
    </HelpDialog>

    <div class="mb-2 flex items-center gap-2">
        <label class="block text-sm font-medium text-neutral-300">@Label</label>

        @if (HasHelp)
        {
            <button type="button"
                    @onclick="() => _showHelp = true"
                    class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 text-[0.7rem] font-semibold text-fuchsia-100 transition hover:bg-fuchsia-400/20"
                    aria-label="Help for @Label">
                ?
            </button>
        }
    </div>

    <textarea value="@Value"
              @oninput="OnTextChanged"
              class="min-h-28 w-full rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-white outline-none"
              @attributes="AdditionalAttributes"></textarea>

    @if (!string.IsNullOrWhiteSpace(Eyebrow))
    {
        <p class="mt-2 text-sm text-neutral-400">@Eyebrow</p>
    }

    @if (!string.IsNullOrWhiteSpace(Error))
    {
        <p class="mt-2 text-sm text-red-300">@Error</p>
    }
</div>

@code {
    private bool _showHelp;
    private bool HasHelp => !string.IsNullOrWhiteSpace(HelpText) || ChildContent is not null;

    [Parameter, EditorRequired]
    public string Label { get; set; } = "";

    [Parameter]
    public string? Title { get; set; }

    private string EffectiveTitle => string.IsNullOrWhiteSpace(Title) ? Label : Title;

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public string? HelpText { get; set; }

    [Parameter]
    public string? Eyebrow { get; set; }

    [Parameter]
    public string? Error { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private Task OnTextChanged(ChangeEventArgs eventArgs)
    {
        string? nextValue = eventArgs.Value?.ToString();
        Value = nextValue;
        return ValueChanged.InvokeAsync(nextValue);
    }
}