<header class="relative z-20 border-b border-fuchsia-400/10 bg-black/20 shadow-[0_10px_28px_rgba(0,0,0,0.12)] backdrop-blur-[2px]">
    <div class="mx-auto flex max-w-7xl flex-col gap-4 px-6 py-5 lg:px-8">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
            <a href="" class="flex items-center gap-3">
                <span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-fuchsia-300/30 bg-fuchsia-400/15 text-sm font-semibold text-fuchsia-100 shadow-[0_0_20px_rgba(168,85,247,0.35)]">
                    ASA
                </span>
                <span>
                    <span class="block text-[0.7rem] uppercase tracking-[0.35em] text-fuchsia-200/85">ASA Fleet</span>
                    <span class="block text-lg font-semibold text-white">Global ASA neon control</span>
                </span>
            </a>

            <AuthorizeView>
                <Authorized>
                    <div class="rounded-full border border-fuchsia-400/10 bg-white/5 px-4 py-2 text-xs uppercase tracking-[0.24em] text-fuchsia-100 shadow-[0_0_18px_rgba(168,85,247,0.15)]">
                        Authenticated command layer
                    </div>
                </Authorized>
                <NotAuthorized>
                    <a href="/admin/login"
                       class="rounded-full border border-fuchsia-400/10 bg-white/5 px-4 py-2 text-xs uppercase tracking-[0.24em] text-fuchsia-100 shadow-[0_0_18px_rgba(168,85,247,0.15)] transition hover:bg-fuchsia-400/15">
                        Admin login
                    </a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <div>
            <nav class="flex flex-wrap gap-3">
                <NavLink href=""
                         Match="NavLinkMatch.All"
                         class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100 shadow-[0_0_18px_rgba(168,85,247,0.15)] transition hover:bg-fuchsia-400/15"
                         ActiveClass="border-fuchsia-300/40 bg-fuchsia-400/20 text-white shadow-[0_0_22px_rgba(168,85,247,0.35)]">
                    Home
                </NavLink>

                <AuthorizeView>
                    <Authorized>
                        <NavLink href="/admin/dashboard"
                                 Match="NavLinkMatch.All"
                                 class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100 shadow-[0_0_18px_rgba(168,85,247,0.15)] transition hover:bg-fuchsia-400/15"
                                 ActiveClass="border-fuchsia-300/40 bg-fuchsia-400/20 text-white shadow-[0_0_22px_rgba(168,85,247,0.35)]">
                            Dashboard
                        </NavLink>

                        <NavLink href="/admin/servers"
                                 class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100 shadow-[0_0_18px_rgba(168,85,247,0.15)] transition hover:bg-fuchsia-400/15"
                                 ActiveClass="border-fuchsia-300/40 bg-fuchsia-400/20 text-white shadow-[0_0_22px_rgba(168,85,247,0.35)]">
                            Servers
                        </NavLink>

                        <NavLink href="/admin/cluster"
                                 class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100 shadow-[0_0_18px_rgba(168,85,247,0.15)] transition hover:bg-fuchsia-400/15"
                                 ActiveClass="border-fuchsia-300/40 bg-fuchsia-400/20 text-white shadow-[0_0_22px_rgba(168,85,247,0.35)]">
                            Cluster
                        </NavLink>

                        <NavLink href="/admin/invitations"
                                 class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100 shadow-[0_0_18px_rgba(168,85,247,0.15)] transition hover:bg-fuchsia-400/15"
                                 ActiveClass="border-fuchsia-300/40 bg-fuchsia-400/20 text-white shadow-[0_0_22px_rgba(168,85,247,0.35)]">
                            Invitations
                        </NavLink>

                        <NavLink href="/admin/mods"
                                 class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100 shadow-[0_0_18px_rgba(168,85,247,0.15)] transition hover:bg-fuchsia-400/15"
                                 ActiveClass="border-fuchsia-300/40 bg-fuchsia-400/20 text-white shadow-[0_0_22px_rgba(168,85,247,0.35)]">
                            Mods
                        </NavLink>

                        <NavLink href="/admin/logs"
                                 class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100 shadow-[0_0_18px_rgba(168,85,247,0.15)] transition hover:bg-fuchsia-400/15"
                                 ActiveClass="border-fuchsia-300/40 bg-fuchsia-400/20 text-white shadow-[0_0_22px_rgba(168,85,247,0.35)]">
                            Logs
                        </NavLink>

                        <NavLink href="/admin/server-settings"
                                 class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100 shadow-[0_0_18px_rgba(168,85,247,0.15)] transition hover:bg-fuchsia-400/15"
                                 ActiveClass="border-fuchsia-300/40 bg-fuchsia-400/20 text-white shadow-[0_0_22px_rgba(168,85,247,0.35)]">
                            Server Settings
                        </NavLink>

                        <NavLink href="/admin/user-settings"
                                 class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100 shadow-[0_0_18px_rgba(168,85,247,0.15)] transition hover:bg-fuchsia-400/15"
                                 ActiveClass="border-fuchsia-300/40 bg-fuchsia-400/20 text-white shadow-[0_0_22px_rgba(168,85,247,0.35)]">
                            User Settings
                        </NavLink>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView>
                    <Authorized>
                        <form method="post" action="/auth/logout" @formname="logout" class="contents">
                            <button type="submit"
                                    class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100 shadow-[0_0_18px_rgba(168,85,247,0.15)] transition hover:bg-fuchsia-400/15">
                                Logout
                            </button>
                        </form>
                    </Authorized>
                </AuthorizeView>
            </nav>
        </div>
    </div>
</header>
