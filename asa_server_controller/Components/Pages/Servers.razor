	private string GetDisplayStateLabel(ServerListItem item)
	{
		return IsServerInstalled(item.Id)
			? item.StateLabel
			: "Uninstalled";
	}

	private bool IsServerInstalled(int remoteServerId)
	{
		RemoteInstallStateSnapshot snapshot =
			RemoteServerInstallStateHubClientService.GetSnapshot(remoteServerId);

		if (!string.Equals(snapshot.ConnectionState, "Connected", StringComparison.Ordinal))
		{
			return false;
		}

		return string.Equals(snapshot.Workspace.Proton.Status, "OK", StringComparison.OrdinalIgnoreCase) &&
			string.Equals(snapshot.Workspace.Steam.Status, "OK", StringComparison.OrdinalIgnoreCase) &&
			string.Equals(snapshot.Workspace.StartScript.Status, "OK", StringComparison.OrdinalIgnoreCase) &&
			string.Equals(snapshot.Workspace.ServiceFile.Status, "OK", StringComparison.OrdinalIgnoreCase);
	}

	private static string BuildActionLabel(string actionName)
	{
		return actionName switch
		{
			"start" => "Start",
			"stop" => "Stop",
			"install" => "Install",
			_ => "Remote server"
		};
	}

	private void HandleServerStateToasts(IReadOnlyList<ServerListItem> previousItems, IReadOnlyList<ServerListItem> currentItems)
	{
		if (!_page.HasLoadedServerStates)
		{
			_page.ServerOnlineStates.Clear();
			foreach (ServerListItem item in currentItems)
			{
				_page.ServerOnlineStates[item.Id] = item.IsOnline;
			}

			_page.HasLoadedServerStates = true;
			return;
		}

		foreach (ServerListItem item in currentItems)
		{
			bool hadPreviousState = _page.ServerOnlineStates.TryGetValue(item.Id, out bool previousIsOnline);
			_page.ServerOnlineStates[item.Id] = item.IsOnline;

			if (!hadPreviousState || previousIsOnline == item.IsOnline || !IsServerInstalled(item.Id))
			{
				continue;
			}

			string serverTitle = GetServerTitle(item);
			if (item.IsOnline)
			{
				ToastService.ShowSuccess($"{serverTitle} started.", "Server");
			}
			else
			{
				ToastService.ShowInfo($"{serverTitle} stopped.", "Server");
			}
		}
	}

