@page "/admin/servers"
@using RemoteInstallStateSnapshot = asa_server_controller.Models.Install.RemoteInstallStateSnapshot
@using RemoteManagerCommandResponse = asa_server_controller.Models.Servers.RemoteManagerCommandResponse
@using ServerListItem = asa_server_controller.Models.Servers.RemoteServerListItem
@inject asa_server_controller.Services.RemoteServerService RemoteServerService
@inject asa_server_controller.Services.RemoteManagerService RemoteManagerService
@inject asa_server_controller.Services.RemoteServerHubClientService RemoteServerHubClientService
@inject asa_server_controller.Services.RemoteServerInstallStateHubClientService RemoteServerInstallStateHubClientService
@inject asa_server_controller.Services.RemoteServerInfoService RemoteServerInfoService
@inject asa_server_controller.Services.ToastService ToastService
@inject asa_server_controller.Services.VpnService VpnService
@implements IDisposable

<PageTitle>Servers</PageTitle>

<section
	class="rounded-b-[2rem] border-x border-b border-fuchsia-400/15 bg-gradient-to-br from-black/35 via-[#0b0612]/30 to-[#17081f]/35 p-8 shadow-[0_0_48px_rgba(168,85,247,0.16)] backdrop-blur-[2px]">
	<div class="space-y-8">
		<div class="flex flex-wrap items-center gap-4">
			<p class="text-[0.7rem] uppercase tracking-[0.35em] text-fuchsia-200/85">Servers</p>
			<span
				class="rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100">
				Fleet registry
			</span>
		</div>

		<div>
			<h1 class="text-4xl font-semibold tracking-tight text-white">Servers</h1>
			<p class="mt-4 max-w-3xl text-sm leading-7 text-neutral-300">
				This page will show other servers info for the whole fleet: connection state, handshake health, VPN identity,
				and shared manager visibility.
			</p>
		</div>

		<div class="flex flex-wrap items-center justify-between gap-3">
			<p class="text-sm text-neutral-300">Servers are created automatically when an invitation link is generated. Edit
				their VPN address or node port here if needed.</p>
		</div>

		<div class="rounded-[1.4rem] border border-fuchsia-400/15 bg-fuchsia-400/5 p-4 text-sm leading-6 text-neutral-300">
			Player count on this page comes from RCON polling. If the server is down or RCON is unavailable, player data stays at `0`.
		</div>

		<div class="rounded-[1.75rem] border border-fuchsia-400/15 bg-black/25 p-6 shadow-[0_0_30px_rgba(192,132,252,0.14)] backdrop-blur-xl">
			<p class="text-[0.7rem] uppercase tracking-[0.3em] text-fuchsia-200/85">Required ports</p>
			<div class="mt-4 flex flex-wrap gap-4">
				<div class="relative min-w-48 flex-1 rounded-2xl border border-white/10 bg-black/20 p-4 pr-16">
					<InlineHelpButton OnClick="@(() => OpenHelpDialog("VPN port", "This port belongs to the control machine. Forward it to the controller so remote nodes can join the VPN."))"
									  Class="absolute right-4 top-4" />
					<p class="text-xs uppercase tracking-[0.2em] text-neutral-400">VPN</p>
					<p class="mt-2 text-2xl font-semibold text-white">@_page.VpnPort</p>
					<p class="mt-2 text-sm text-neutral-300">WireGuard listen port. User configurable.</p>
				</div>

				<div class="relative min-w-48 flex-1 rounded-2xl border border-white/10 bg-black/20 p-4 pr-16">
					<InlineHelpButton OnClick="@(() => OpenHelpDialog("Control web app", "This port belongs to the control machine. Forward it if you want the controller reachable from outside."))"
									  Class="absolute right-4 top-4" />
					<p class="text-xs uppercase tracking-[0.2em] text-neutral-400">Web app</p>
					<p class="mt-2 text-2xl font-semibold text-white">8010</p>
					<p class="mt-2 text-sm text-neutral-300">Control web app port.</p>
				</div>
			</div>
		</div>

		@if (_page.Items.Count == 0)
		{
			<div
				class="rounded-[1.75rem] border border-fuchsia-400/15 bg-black/25 p-6 shadow-[0_0_30px_rgba(192,132,252,0.14)] backdrop-blur-xl">
				<p class="text-[0.7rem] uppercase tracking-[0.3em] text-fuchsia-200/85">Overview</p>
				<p class="mt-3 text-2xl font-semibold text-white">No servers yet</p>
				<p class="mt-2 text-sm text-neutral-300">Create an invitation link from the Invitations page. The server entry
					will appear here immediately.</p>
			</div>
		}
		else
		{
			<div class="space-y-4">
				@foreach (ServerListItem item in _page.Items)
				{
					<div
						class="relative overflow-hidden rounded-[1.75rem] border border-fuchsia-400/15 bg-black/25 p-6 shadow-[0_0_30px_rgba(192,132,252,0.14)] backdrop-blur-xl">
						<div class="w-full pr-14 xl:pr-0">
							<StatusTag Text="@GetDisplayStateLabel(item)" />
						</div>

						<div class="mt-5 w-full">
							<div class="flex flex-col gap-6 xl:flex-row xl:items-start">
								<div class="min-w-0 space-y-4 xl:w-3/4">
									<div>
										<h2 class="text-2xl font-semibold leading-tight text-white">@GetServerTitle(item)</h2>
										<p class="mt-2 break-all text-sm text-neutral-300">Contact URL: @GetContactUrl(item)</p>
									</div>

									<div class="space-y-1 text-sm text-neutral-300">
										<p>VPN address: @item.VpnAddress</p>
										<p>Node API port: @(item.Port?.ToString() ?? "Not set")</p>
										<p>Game port: @(item.GamePort?.ToString() ?? "Missing")</p>
										@if (!IsServerInstalled(item.Id))
										{
											<p>Server not installed yet</p>
										}
										else if (item.IsOnline)
										{
											<p>Map: @(string.IsNullOrWhiteSpace(item.MapName) ? "Unknown" : item.MapName)</p>
											<p>Players: @item.CurrentPlayers / @(item.MaxPlayers > 0 ? item.MaxPlayers : 0)</p>
											@if (!item.CanSendRconCommand)
											{
												<p class="text-xs text-neutral-400">Player count requires RCON. Without it, this stays at 0.</p>
											}
										}
										else
										{
											<p>Server offline</p>
										}
										<p>Created: @item.CreatedAtUtc.LocalDateTime</p>
										<p>Last seen: @(item.LastSeenAtUtc?.LocalDateTime.ToString() ?? "Never")</p>
									</div>

									@if (_page.ServerMessages.TryGetValue(item.Id, out string? serverMessage) &&
										!string.IsNullOrWhiteSpace(serverMessage))
									{
										<p class="max-w-2xl text-xs text-neutral-300">@serverMessage</p>
									}
								</div>

								<div class="hidden xl:flex xl:w-1/4 xl:flex-col xl:items-stretch xl:justify-start xl:gap-2">
									@if (IsServerInstalled(item.Id))
									{
										<ActionButton Text="Edit connection" Secondary="true" OnClick="@(() => OpenEditServerDialog(item))" />
										<ActionButton Text="Edit config" Secondary="true" OnClick="@(() => OpenEditServerConfigDialogAsync(item))" />
										<ActionButton Text="Start" Disabled="@(IsStartBusy(item.Id) || !item.CanStart)"
											OnClick="@(() => StartServerAsync(item.Id))" />
										<ActionButton Text="Stop" Disabled="@(IsStopBusy(item.Id) || !item.CanStop)" Secondary="true"
											OnClick="@(() => StopServerAsync(item.Id))" />
										<ActionButton Text="Open RCON" Disabled="@(!item.CanSendRconCommand)" Secondary="true"
											OnClick="@(() => OpenRconDialogAsync(item))" />
									}
									else
									{
										<ActionButton Text="Install" Disabled="@IsInstallBusy(item.Id)"
											OnClick="@(() => InstallServerAsync(item.Id))" />
									}
									<button type="button" @onclick="() => OpenDeleteServerDialog(item)"
										class="inline-flex w-full items-center justify-center rounded-full border border-red-300/20 bg-red-400/10 px-4 py-2 text-center text-xs font-semibold uppercase tracking-[0.2em] text-red-100 transition hover:bg-red-400/20">
										Delete
									</button>
								</div>
							</div>
						</div>

						<div class="absolute right-6 top-6 xl:hidden">
							<button type="button" @onclick="() => ToggleActionMenu(item.Id)"
								class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 text-lg text-fuchsia-100 transition hover:bg-fuchsia-400/20">
								&#9881;
							</button>
						</div>

						@if (_page.OpenActionMenuServerId == item.Id)
						{
							<div class="absolute inset-0 z-20 flex xl:hidden">
								<div class="flex h-full w-full flex-col rounded-[1.75rem] border border-fuchsia-300/20 bg-[#12081b]/96 p-6 shadow-[0_0_35px_rgba(168,85,247,0.18)] backdrop-blur-xl">
									<div class="flex items-start justify-between gap-4">
										<div>
											<p class="text-xs font-semibold uppercase tracking-[0.28em] text-fuchsia-300">Server actions</p>
											<p class="mt-2 text-lg font-semibold text-white">@GetServerTitle(item)</p>
										</div>

										<button type="button" @onclick="() => ToggleActionMenu(item.Id)"
											class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/5 text-lg text-neutral-200 transition hover:bg-white/10">
											&#10005;
										</button>
									</div>

									<div class="mt-5 flex-1 space-y-2">
										@if (IsServerInstalled(item.Id))
										{
											<ActionButton Text="Edit connection" Secondary="true" OnClick="@(() => OpenEditServerFromMenu(item))" />
											<ActionButton Text="Edit config" Secondary="true" OnClick="@(() => OpenEditServerConfigFromMenuAsync(item))" />
											<ActionButton Text="Start" Disabled="@(IsStartBusy(item.Id) || !item.CanStart)"
												OnClick="@(() => StartServerFromMenuAsync(item.Id))" />
											<ActionButton Text="Stop" Disabled="@(IsStopBusy(item.Id) || !item.CanStop)" Secondary="true"
												OnClick="@(() => StopServerFromMenuAsync(item.Id))" />
											<ActionButton Text="Open RCON" Disabled="@(!item.CanSendRconCommand)" Secondary="true"
												OnClick="@(() => OpenRconFromMenuAsync(item))" />
										}
										else
										{
											<ActionButton Text="Install" Disabled="@IsInstallBusy(item.Id)"
												OnClick="@(() => InstallServerFromMenuAsync(item.Id))" />
										}
										<button type="button" @onclick="() => OpenDeleteServerFromMenu(item)"
											class="inline-flex w-full items-center justify-center rounded-full border border-red-300/20 bg-red-400/10 px-4 py-2 text-center text-xs font-semibold uppercase tracking-[0.2em] text-red-100 transition hover:bg-red-400/20">
											Delete
										</button>
									</div>
								</div>
							</div>
						}
					</div>
				}
			</div>
		}
	</div>
</section>

@if (_page.IsEditServerDialogOpen)
{
	<div class="fixed inset-0 z-50 flex items-center justify-center bg-black/55 p-3 backdrop-blur-sm sm:p-6"
		 @onclick="CloseEditServerDialog">
		<div
			class="flex max-h-[92vh] w-full max-w-3xl flex-col overflow-hidden rounded-[1.8rem] border border-fuchsia-400/15 bg-[#05070d]/94 shadow-[0_0_80px_rgba(168,85,247,0.18)] backdrop-blur-xl"
			@onclick:stopPropagation="true">
			<div class="relative shrink-0 border-b border-white/10 px-5 py-5 pr-20 sm:px-6">
				<div>
					<div class="flex flex-wrap items-center gap-3">
						<p class="text-xs font-semibold uppercase tracking-[0.45em] text-fuchsia-300">Servers</p>
						<span class="rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100">
							Connection
						</span>
					</div>
					<h2 class="mt-3 text-3xl font-semibold text-white">Edit remote connection</h2>
					<p class="mt-3 text-sm leading-6 text-neutral-300">Adjust the VPN address or the remote web app port used by
						the control app.</p>
				</div>

				<button type="button" @onclick="CloseEditServerDialog"
					class="absolute right-5 top-5 inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/5 text-lg text-neutral-200 transition hover:bg-white/10 sm:right-6">
					&#10005;
				</button>
			</div>

			<div class="min-h-0 flex-1 overflow-y-auto p-5 sm:p-6">
				<div class="space-y-5">
					@if (!string.IsNullOrWhiteSpace(_page.DialogStatusMessage))
					{
						<div class="@GetDialogStatusMessageClass()">
							@_page.DialogStatusMessage
						</div>
					}

					<div class="grid gap-4 md:grid-cols-2">
						<TextField Label="VPN address" @bind-Value="_page.SelectedVpnAddress" Hint="Example: 10.10.10.3/32"
							autocomplete="off" />

						<TextField Label="Port" @bind-Value="_page.SelectedPort"
							Hint="Optional. Default node web app port is usually 8000." autocomplete="off" />
					</div>

					<div class="flex justify-end gap-3 pt-2">
						<button type="button" @onclick="CloseEditServerDialog"
							class="inline-flex rounded-full border border-white/10 bg-white/5 px-5 py-2.5 text-sm font-medium text-neutral-200 transition hover:bg-white/10">
							Close
						</button>

						<button type="button" @onclick="SaveServerAsync" disabled="@_page.IsSavingServer"
							class="inline-flex rounded-full border border-fuchsia-300/30 bg-fuchsia-400/15 px-5 py-2.5 text-sm font-medium text-fuchsia-100 transition hover:bg-fuchsia-400/25 disabled:cursor-not-allowed disabled:opacity-60">
							@(_page.IsSavingServer ? "Saving..." : "Save")
						</button>
					</div>
				</div>
			</div>
		</div>
	</div>
}

<EditServerConfigDialog IsOpen="@_page.IsEditServerConfigDialogOpen"
						RemoteServerId="@_page.EditServerConfigRemoteServerId"
						ServerTitle="@_page.SelectedConfigServerTitle"
						OnClose="CloseEditServerConfigDialog"
						OnSaved="RefreshAsync" />

<RconDialog IsOpen="@_page.IsRconDialogOpen"
			RemoteServerId="@_page.RconRemoteServerId"
			CanSendRconCommand="@_page.CanSendRconCommand"
			OnClose="CloseRconDialog" />

<ConfirmationDialog IsOpen="@_page.IsDeleteServerDialogOpen"
					IsBusy="@_page.IsDeletingServer"
					Eyebrow="Servers"
					PillText="Delete"
					Title="Delete remote server?"
					Message="@($"Delete {_page.DeleteServerTitle}? This removes the server, VPN invitations, NFS invitations, and linked mod usage.")"
					ConfirmText="Delete"
					CancelText="Cancel"
					OnConfirm="DeleteSelectedServerAsync"
					OnCancel="CloseDeleteServerDialog" />

<InfoDialog IsOpen="@_page.ShowHelpDialog"
			Eyebrow="Ports"
			Title="@_page.HelpDialogTitle"
			Message="@_page.HelpDialogMessage"
			PillText="Help"
			OnClose="CloseHelpDialog" />

@code {
private readonly ServerPageModel _page = new();

	protected override async Task OnInitializedAsync()
	{
		RemoteServerHubClientService.Changed += OnRemoteServerChanged;
		RemoteServerInstallStateHubClientService.Changed += OnRemoteInstallStateChanged;
		RemoteServerInfoService.InfoUpdated += OnRemoteInfoUpdated;
		await RefreshAsync();
	}

	public void Dispose()
	{
		RemoteServerHubClientService.Changed -= OnRemoteServerChanged;
		RemoteServerInstallStateHubClientService.Changed -= OnRemoteInstallStateChanged;
		RemoteServerInfoService.InfoUpdated -= OnRemoteInfoUpdated;
	}

	private async Task RefreshAsync()
	{
		_page.IsRefreshing = true;

		try
		{
			IReadOnlyList<ServerListItem> previousItems = _page.Items;
			_page.Items = await RemoteServerService.LoadAsync();
			_page.VpnPort = await VpnService.LoadCurrentListenPortAsync();
			HandleServerStateToasts(previousItems, _page.Items);
		}
		finally
		{
			_page.IsRefreshing = false;
		}
	}

	private void OnRemoteServerChanged(int remoteServerId)
	{
		_ = InvokeAsync(async () =>
		{
			if (_page.IsRefreshing)
			{
				return;
			}

			await RefreshAsync();
			StateHasChanged();
		});
	}

	private void OnRemoteInfoUpdated(int remoteServerId)
	{
		_ = InvokeAsync(async () =>
		{
			if (_page.IsRefreshing)
			{
				return;
			}

			await RefreshAsync();
			StateHasChanged();
		});
	}

	private void OnRemoteInstallStateChanged(int remoteServerId)
	{
		_ = InvokeAsync(async () =>
		{
			if (_page.IsRefreshing)
			{
				return;
			}

			await RefreshAsync();
			StateHasChanged();
		});
	}

	private void OpenEditServerDialog(ServerListItem item)
	{
		_page.OpenActionMenuServerId = null;
		_page.DialogStatusMessage = null;
		_page.DialogStatusIsError = false;
		_page.EditConnectionRemoteServerId = item.Id;
		_page.SelectedVpnAddress = item.VpnAddress;
		_page.SelectedPort = item.Port?.ToString() ?? asa_server_controller.Services.RemoteServerService.DefaultRemoteServerPort;
		_page.IsEditServerDialogOpen = true;
	}

	private void CloseEditServerDialog()
	{
		_page.IsEditServerDialogOpen = false;
		_page.DialogStatusMessage = null;
		_page.DialogStatusIsError = false;
		ResetEditServerModel();
	}

	private async Task OpenEditServerConfigDialogAsync(ServerListItem item)
	{
		_page.OpenActionMenuServerId = null;
		_page.IsEditServerConfigDialogOpen = true;
		_page.EditServerConfigRemoteServerId = item.Id;
		_page.SelectedConfigServerTitle = GetServerTitle(item);
		await Task.CompletedTask;
	}

	private void CloseEditServerConfigDialog()
	{
		_page.IsEditServerConfigDialogOpen = false;
		_page.EditServerConfigRemoteServerId = 0;
		_page.SelectedConfigServerTitle = "this server";
	}

	private async Task SaveServerAsync()
	{
		_page.IsSavingServer = true;
		_page.DialogStatusMessage = null;
		_page.DialogStatusIsError = false;

		try
		{
			await RemoteServerService.UpdateAsync(_page.EditConnectionRemoteServerId, _page.SelectedVpnAddress ?? string.Empty, _page.SelectedPort);
			CloseEditServerDialog();
			await RefreshAsync();
		}
		catch (Exception exception)
		{
			_page.DialogStatusMessage = exception.Message;
			_page.DialogStatusIsError = true;
		}
		finally
		{
			_page.IsSavingServer = false;
		}
	}

	private async Task StartServerAsync(int remoteServerId)
	{
		await RunManagerCommandAsync(remoteServerId, "start", () => RemoteManagerService.StartAsync(remoteServerId));
	}

	private async Task StopServerAsync(int remoteServerId)
	{
		await RunManagerCommandAsync(remoteServerId, "stop", () => RemoteManagerService.StopAsync(remoteServerId));
	}

	private async Task InstallServerAsync(int remoteServerId)
	{
		await RunManagerCommandAsync(remoteServerId, "install", () => RemoteManagerService.InstallAllAsync(remoteServerId));
	}

	private async Task RunManagerCommandAsync(
		int remoteServerId,
		string actionName,
		Func<Task<RemoteManagerCommandResponse>> action)
	{
		if (_page.BusyActions.ContainsKey(remoteServerId))
		{
			return;
		}

		_page.BusyActions[remoteServerId] = actionName;

		try
		{
			RemoteManagerCommandResponse response = await action();
			_page.ServerMessages[remoteServerId] = response.Message;
			ToastService.ShowSuccess($"{BuildActionLabel(actionName)} command sent.", "Command");
			await RefreshAsync();
		}
		catch (Exception exception)
		{
			_page.ServerMessages[remoteServerId] = exception.Message;
		}
		finally
		{
			_page.BusyActions.Remove(remoteServerId);
		}
	}

	private bool IsStartBusy(int remoteServerId)
	{
		return _page.BusyActions.TryGetValue(remoteServerId, out string? actionName) &&
			string.Equals(actionName, "start", StringComparison.Ordinal);
	}

	private bool IsStopBusy(int remoteServerId)
	{
		return _page.BusyActions.TryGetValue(remoteServerId, out string? actionName) &&
			string.Equals(actionName, "stop", StringComparison.Ordinal);
	}

	private bool IsInstallBusy(int remoteServerId)
	{
		return _page.BusyActions.TryGetValue(remoteServerId, out string? actionName) &&
			string.Equals(actionName, "install", StringComparison.Ordinal);
	}

	private async Task OpenRconDialogAsync(ServerListItem item)
	{
		_page.OpenActionMenuServerId = null;
		_page.RconRemoteServerId = item.Id;
		_page.CanSendRconCommand = item.CanSendRconCommand;
		_page.IsRconDialogOpen = true;
		await Task.CompletedTask;
	}

	private void CloseRconDialog()
	{
		_page.IsRconDialogOpen = false;
		_page.RconRemoteServerId = 0;
		_page.CanSendRconCommand = false;
	}

	private void OpenDeleteServerDialog(ServerListItem item)
	{
		_page.OpenActionMenuServerId = null;
		_page.DeleteRemoteServerId = item.Id;
		_page.DeleteServerTitle = GetServerTitle(item);
		_page.IsDeleteServerDialogOpen = true;
	}

	private void CloseDeleteServerDialog()
	{
		if (_page.IsDeletingServer)
		{
			return;
		}

		_page.IsDeleteServerDialogOpen = false;
		_page.DeleteRemoteServerId = 0;
		_page.DeleteServerTitle = "this server";
	}

	private async Task DeleteSelectedServerAsync()
	{
		if (_page.DeleteRemoteServerId <= 0)
		{
			return;
		}

		_page.IsDeletingServer = true;

		try
		{
			await RemoteServerService.DeleteAsync(_page.DeleteRemoteServerId);
			_page.IsDeleteServerDialogOpen = false;
			_page.DeleteRemoteServerId = 0;
			_page.DeleteServerTitle = "this server";
			ToastService.ShowSuccess("Remote server deleted.", "Server");
			await RefreshAsync();
		}
		catch (Exception exception)
		{
			_page.ServerMessages[_page.DeleteRemoteServerId] = exception.Message;
			_page.IsDeleteServerDialogOpen = false;
			await RefreshAsync();
		}
		finally
		{
			_page.IsDeletingServer = false;
		}
	}

	private void ResetEditServerModel()
	{
		_page.EditConnectionRemoteServerId = 0;
		_page.SelectedVpnAddress = null;
		_page.SelectedPort = asa_server_controller.Services.RemoteServerService.DefaultRemoteServerPort;
	}

	private string GetDialogStatusMessageClass()
	{
		return _page.DialogStatusIsError
			? "rounded-2xl border border-red-300/20 bg-red-400/10 px-5 py-4 text-sm text-red-100"
			: "rounded-2xl border border-emerald-300/20 bg-emerald-400/10 px-5 py-4 text-sm text-emerald-100";
	}

	private static string GetContactUrl(ServerListItem item)
	{
		string host = item.VpnAddress.Split('/', 2, StringSplitOptions.TrimEntries)[0];
		bool isDomain = Uri.CheckHostName(host) == UriHostNameType.Dns;

		if (!item.Port.HasValue)
		{
			return isDomain ? $"https://{host}" : "Port not set";
		}

		return isDomain
			? $"https://{host}:{item.Port.Value}"
			: $"http://{host}:{item.Port.Value}";
	}

	private static string GetServerTitle(ServerListItem item)
	{
		return string.IsNullOrWhiteSpace(item.ServerName)
			? $"Server {item.Id}"
			: item.ServerName;
	}

	private void ToggleActionMenu(int remoteServerId)
	{
		_page.OpenActionMenuServerId = _page.OpenActionMenuServerId == remoteServerId ? null : remoteServerId;
	}

	private void OpenEditServerFromMenu(ServerListItem item)
	{
		_page.OpenActionMenuServerId = null;
		OpenEditServerDialog(item);
