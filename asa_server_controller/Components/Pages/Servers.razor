	private string GetDisplayStateLabel(asa_server_controller.Models.Servers.RemoteServerListItem item)
	{
		return IsServerInstalled(item.Id)
			? item.StateLabel
			: "Uninstalled";
	}

	private bool IsServerInstalled(int remoteServerId)
	{
		asa_server_controller.Models.Install.RemoteInstallStateSnapshot snapshot =
			RemoteServerInstallStateHubClientService.GetSnapshot(remoteServerId);

		if (!string.Equals(snapshot.ConnectionState, "Connected", StringComparison.Ordinal))
		{
			return false;
		}

		return string.Equals(snapshot.Workspace.Proton.Status, "OK", StringComparison.OrdinalIgnoreCase) &&
			string.Equals(snapshot.Workspace.Steam.Status, "OK", StringComparison.OrdinalIgnoreCase) &&
			string.Equals(snapshot.Workspace.StartScript.Status, "OK", StringComparison.OrdinalIgnoreCase) &&
			string.Equals(snapshot.Workspace.ServiceFile.Status, "OK", StringComparison.OrdinalIgnoreCase);
	}
