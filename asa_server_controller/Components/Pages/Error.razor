@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<div class="rounded-b-[2rem] border-x border-b border-red-400/20 bg-red-500/10 p-8 text-red-50 shadow-[0_0_40px_rgba(255,0,0,0.15)] backdrop-blur-[2px]">
    <p class="text-[0.7rem] uppercase tracking-[0.35em] text-red-100/80">Manager Web App</p>
    <h1 class="mt-3 text-3xl font-semibold">Error</h1>
    <h2 class="mt-2 text-lg text-red-100/90">An error occurred while processing your request.</h2>

    @if (ShowRequestId)
    {
        <p class="mt-4 text-sm text-red-100/90">
            <strong>Request ID:</strong> <code>@RequestId</code>
        </p>
    }

    <p class="mt-6 text-sm leading-7 text-red-100/90">
        Development mode shows more details. Keep it disabled in production.
    </p>
</div>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
