@page "/admin/logs"
@implements IAsyncDisposable
@using asa_server_controller.Models.Logs
@inject asa_server_controller.Services.LogsService LogsService

<PageTitle>Logs</PageTitle>

<section class="rounded-b-[2rem] border-x border-b border-fuchsia-400/15 bg-gradient-to-br from-black/35 via-[#0b0612]/30 to-[#17081f]/35 p-8 shadow-[0_0_48px_rgba(168,85,247,0.16)] backdrop-blur-[2px]">
    <div class="space-y-8">
        <div class="flex flex-wrap items-center gap-4">
            <p class="text-[0.7rem] uppercase tracking-[0.35em] text-fuchsia-200/85">Logs</p>
            <span class="rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100">
                WireGuard
            </span>
        </div>

        <div>
            <h1 class="text-4xl font-semibold tracking-tight text-white">Logs</h1>
            <p class="mt-4 max-w-3xl text-sm leading-7 text-neutral-300">
                Live status for <code class="rounded bg-white/10 px-2 py-1 text-neutral-100">wg-quick@wg0.service</code>. This page refreshes every 5 seconds.
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(_loadError))
        {
            <div class="rounded-2xl border border-red-300/20 bg-red-400/10 px-5 py-4 text-sm text-red-100">
                @_loadError
            </div>
        }

        <div class="space-y-6">
            @foreach (LogSectionSnapshot logSection in GetSections())
            {
                <section class="rounded-[1.6rem] border border-white/10 bg-black/40 p-6 shadow-[0_0_30px_rgba(168,85,247,0.08)]">
                    <div class="space-y-3">
                        <div class="flex flex-wrap items-center gap-3">
                            <h2 class="text-2xl font-semibold text-white">@logSection.Title</h2>
                            <StatusTag Text="@(logSection.IsAvailable ? "OK" : "Missing")" />
                        </div>

                        <p class="text-sm leading-6 text-neutral-300">@logSection.Description</p>
                    </div>

                    <pre class="mt-5 h-[20rem] overflow-auto rounded-[1.2rem] border border-white/10 bg-[#05070d] p-4 font-mono text-sm leading-6 whitespace-pre-wrap text-fuchsia-100 shadow-[inset_0_0_25px_rgba(168,85,247,0.08)]">@logSection.Content</pre>
                </section>
            }
        </div>
    </div>
</section>

@code {
    private ControlLogsSnapshot _snapshot = new(
        new LogSectionSnapshot("WireGuard status", "Live systemctl status output for wg-quick@wg0.", "Loading...", false),
        DateTimeOffset.UtcNow);
    private CancellationTokenSource? _refreshLoopCancellationTokenSource;
    private bool _isRefreshing;
    private string? _loadError;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        _refreshLoopCancellationTokenSource = new CancellationTokenSource();
        _ = RunRefreshLoopAsync(_refreshLoopCancellationTokenSource.Token);
    }

    private async Task RefreshAsync()
    {
        if (_isRefreshing)
        {
            return;
        }

        _isRefreshing = true;

        try
        {
            _snapshot = await LogsService.LoadAsync();
            _loadError = null;
        }
        catch (Exception exception)
        {
            _loadError = exception.Message;
        }
        finally
        {
            _isRefreshing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RunRefreshLoopAsync(CancellationToken cancellationToken)
    {
        try
        {
            using PeriodicTimer timer = new(TimeSpan.FromSeconds(5));

            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await RefreshAsync();
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private IReadOnlyList<LogSectionSnapshot> GetSections()
    {
        return
        [
            _snapshot.WireGuardStatusSection
        ];
    }

    public ValueTask DisposeAsync()
    {
        if (_refreshLoopCancellationTokenSource is not null)
        {
            _refreshLoopCancellationTokenSource.Cancel();
            _refreshLoopCancellationTokenSource.Dispose();
            _refreshLoopCancellationTokenSource = null;
        }

        return ValueTask.CompletedTask;
    }
}
