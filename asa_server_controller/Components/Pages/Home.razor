@page "/"
@inject asa_server_controller.Services.RemoteServerModsService RemoteServerModsService
@inject asa_server_controller.Services.RemoteServerHubClientService RemoteServerHubClientService
@inject asa_server_controller.Services.RemoteServerInfoService RemoteServerInfoService
@inject asa_server_controller.Services.InvitationEventsService InvitationEventsService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@using asa_server_controller.Models.Home;
@using HomeServerModel = asa_server_controller.Models.Home.HomeServerModel
@using PublicServerModItem = asa_server_controller.Models.Servers.PublicServerModItem

<PageTitle>ASA Fleet</PageTitle>

<section
	class="rounded-b-4xl border-x border-b border-fuchsia-400/15 bg-linear-to-br from-black/35 via-[#0b0612]/30 to-[#17081f]/35 p-8 shadow-[0_0_48px_rgba(168,85,247,0.16)] backdrop-blur-[2px]">
	<div class="space-y-8">
		<div class="flex flex-wrap items-center justify-between gap-4">
			<div>
				<p class="text-[0.7rem] uppercase tracking-[0.35em] text-fuchsia-200/85">Public fleet overview</p>
				<h1 class="mt-3 text-4xl font-semibold tracking-tight text-white">Remote ASA servers</h1>
				<p class="mt-4 max-w-3xl text-sm leading-7 text-neutral-300">
					Public status page for the ASA fleet. Open a server card to see the current players and the locally cached mod
					catalog for that node.
				</p>
			</div>
		</div>

		@if (_servers.Count == 0)
		{
			<div
				class="rounded-[1.75rem] border border-fuchsia-400/15 bg-black/25 p-6 shadow-[0_0_30px_rgba(192,132,252,0.14)] backdrop-blur-xl">
				<p class="text-[0.7rem] uppercase tracking-[0.3em] text-fuchsia-200/85">Fleet</p>
				<p class="mt-3 text-2xl font-semibold text-white">No accepted servers yet</p>
				<p class="mt-2 text-sm text-neutral-300">No public server entries yet. Once a remote node accepts an invite, it
					will appear here.</p>
				</div>
			}

				else
			{
				<div class="flex flex-wrap gap-5">
					@foreach (HomeServerModel server in _servers)
					{
						<button type="button" @onclick="() => OpenServerDialog(server)"
										class="flex min-h-64 w-full flex-col justify-between rounded-[1.75rem] border border-fuchsia-400/15 bg-black/25 p-6 text-left shadow-[0_0_30px_rgba(192,132,252,0.14)] backdrop-blur-xl transition hover:border-fuchsia-300/25 hover:bg-black/30 sm:w-[calc(50%-0.625rem)] lg:w-[calc(33.333%-0.875rem)] xl:w-[calc(25%-0.9375rem)]">
							<div class="space-y-5">
								<div class="flex flex-wrap gap-2">
									<StatusTag Text="@server.StateLabel" />
								</div>

								<div>
									<h2 class="text-2xl font-semibold leading-tight text-white">@server.DisplayServerName</h2>
									<p class="mt-2 text-sm text-fuchsia-200/80">@server.FormattedMapName</p>
								</div>
							</div>

							<div class="space-y-3 pt-6">
								<div class="flex items-center justify-between gap-4 text-sm text-neutral-300">
									<span>Players</span>
									<span class="font-semibold text-white">@server.CurrentPlayers / @server.MaxPlayers</span>
								</div>
								<div class="flex items-center justify-between gap-4 text-sm text-neutral-300">
									<span>Mods</span>
									<span class="font-semibold text-white">@server.Mods.Count</span>
								</div>
							</div>
						</button>
					}
				</div>
			}
		</div>
	</section>

	@if (_selectedServer is not null)
	{
		<InfoDialog IsOpen="true" Eyebrow="Server" Title="@_selectedServer.DisplayServerName"
								Message="@_selectedServer.FormattedMapName" CloseText="Close" PillText="Details" MaxWidthClass="max-w-7xl" OnClose="CloseServerDialog">
			<div class="space-y-6">
				<div class="flex flex-wrap gap-2">
					<StatusTag Text="@_selectedServer.StateLabel" />
				</div>

				<section class="rounded-[1.6rem] border border-white/10 bg-black/20 p-5">
					<div class="flex flex-wrap gap-6">
						<div class="min-w-40">
							<p class="text-[0.65rem] uppercase tracking-[0.24em] text-fuchsia-200/70">Players</p>
							<p class="mt-2 text-lg font-semibold text-white">@_selectedServer.CurrentPlayers / @_selectedServer.MaxPlayers
							</p>
						</div>
						<div class="min-w-40">
							<p class="text-[0.65rem] uppercase tracking-[0.24em] text-fuchsia-200/70">Mods</p>
							<p class="mt-2 text-lg font-semibold text-white">@_selectedServer.Mods.Count</p>
						</div>
					</div>
				</section>

				@if (!_hasCurseForgeApiKey && _selectedServer.Mods.Count > 0)
				{
					<section class="rounded-[1.45rem] border border-amber-300/20 bg-amber-400/8 p-4 text-sm text-amber-100/90">
						<p class="text-[0.65rem] uppercase tracking-[0.24em] text-amber-200/80">CurseForge</p>
						<p class="mt-2 leading-6">To show more mod data here, add a CurseForge API key in Server settings.</p>
					</section>
				}

				@if (_selectedServer.Mods.Count == 0)
				{
					<p class="text-sm text-neutral-300">No mods cached for this server yet.</p>
				}
				else
				{
					<MasonryLayout MaxColumns="4" MinColumnWidth="17rem">
						@foreach (PublicServerModItem mod in _selectedServer.Mods)
						{
								@if (mod.HasCurseForgeData)
								{
									<button type="button" @onclick="() => OpenModPage(mod.WebsiteUrl)"
													disabled="@string.IsNullOrWhiteSpace(mod.WebsiteUrl)"
													class="group h-fit w-full overflow-hidden rounded-[1.6rem] border border-fuchsia-200/12 bg-black/40 text-left shadow-[0_0_40px_rgba(168,85,247,0.08)] backdrop-blur-md transition hover:border-fuchsia-300/20 hover:bg-black/45 disabled:cursor-default">
										<div
											class="relative aspect-square w-full shrink-0 overflow-hidden border-b border-fuchsia-200/10 bg-linear-to-br from-fuchsia-400/15 via-[#07121d] to-violet-400/10">
											@if (!string.IsNullOrWhiteSpace(mod.LogoUrl))
											{
												<img src="@mod.LogoUrl" alt="@mod.Name"
														 class="h-full w-full object-cover opacity-95 transition duration-300 group-hover:scale-[1.03]" />
												<div class="absolute inset-0 bg-linear-to-t from-[#05070d] via-[#05070d]/20 to-transparent"></div>
											}
										</div>

										<div class="space-y-3 p-4">
											<h3 class="text-base font-semibold leading-6 text-white wrap-break-word">@mod.Name</h3>
											<p class="text-xs font-semibold uppercase tracking-[0.22em] text-fuchsia-200/75 break-all">@mod.ModId</p>
											@if (!string.IsNullOrWhiteSpace(mod.Summary))
											{
												<p class="text-sm leading-6 text-neutral-300 wrap-break-word">@mod.Summary</p>
											}
										</div>
									</button>
								}
								else
								{
									<div class="rounded-[1.6rem] border border-fuchsia-200/12 bg-black/35 p-4 shadow-[0_0_30px_rgba(168,85,247,0.08)] backdrop-blur-md">
										<p class="text-[0.65rem] uppercase tracking-[0.22em] text-fuchsia-200/75">Mod ID</p>
										<p class="mt-3 break-all text-base font-semibold text-white">@mod.ModId</p>
									</div>
								}
						}
					</MasonryLayout>
				}
			</div>
		</InfoDialog>
	}

@code {
	private IReadOnlyList<HomeServerModel> _servers = [];
	private HomeServerModel? _selectedServer;
	private bool _hasCurseForgeApiKey;
	private bool _isRefreshing;
	private bool _isDisposed;

	protected override async Task OnInitializedAsync()
	{
		RemoteServerHubClientService.Changed += OnRemoteServerChanged;
		RemoteServerInfoService.InfoUpdated += OnRemoteInfoUpdated;
		InvitationEventsService.Changed += OnInvitationChanged;
		await RefreshAsync();
	}

	public void Dispose()
	{
		_isDisposed = true;
		RemoteServerHubClientService.Changed -= OnRemoteServerChanged;
		RemoteServerInfoService.InfoUpdated -= OnRemoteInfoUpdated;
		InvitationEventsService.Changed -= OnInvitationChanged;
	}

	private async Task RefreshAsync()
	{
		if (_isDisposed)
		{
			return;
		}

		_isRefreshing = true;

		try
		{
			ServerDisplay model = await RemoteServerModsService.LoadServerDisplayAsync();
			_servers = model.Servers;
			_hasCurseForgeApiKey = model.HasCurseForgeApiKey;
			if (_selectedServer is not null)
			{
				_selectedServer = _servers.FirstOrDefault(server => server.RemoteServerId == _selectedServer.RemoteServerId);
			}
		}
		finally
		{
			_isRefreshing = false;
		}
	}

	private void OnRemoteServerChanged(int remoteServerId)
	{
		_ = RefreshFromEventAsync();
	}

	private void OnRemoteInfoUpdated(int remoteServerId)
	{
		_ = RefreshFromEventAsync();
	}

	private void OnInvitationChanged()
	{
		_ = RefreshFromEventAsync();
	}

	private Task RefreshFromEventAsync()
	{
		if (_isDisposed)
		{
			return Task.CompletedTask;
		}

		return InvokeAsync(async () =>
		{
			if (_isDisposed || _isRefreshing)
			{
				return;
			}

				await RefreshAsync();
				if (_isDisposed)
				{
					return;
				}

				StateHasChanged();
			});
	}

	private void OpenServerDialog(HomeServerModel server)
	{
		_selectedServer = server;
	}

	private void CloseServerDialog()
	{
		_selectedServer = null;
	}

	private async Task OpenModPage(string? websiteUrl)
	{
		if (string.IsNullOrWhiteSpace(websiteUrl))
		{
			return;
		}

		await JS.InvokeVoidAsync("open", websiteUrl, "_blank", "noopener,noreferrer");
	}
}
