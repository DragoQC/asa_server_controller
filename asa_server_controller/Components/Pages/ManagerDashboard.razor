@page "/admin/dashboard"
@implements IDisposable
@inject asa_server_controller.Services.RemoteServerService RemoteServerService
@inject asa_server_controller.Services.RemoteServerAdminHubClientService RemoteServerAdminHubClientService
@inject asa_server_controller.Services.RemoteServerInfoService RemoteServerInfoService

<PageTitle>Manager Dashboard</PageTitle>

<section class="rounded-b-4xl border-x border-b border-fuchsia-400/15 bg-linear-to-br from-black/35 via-[#0b0612]/30 to-[#17081f]/35 p-8 shadow-[0_0_48px_rgba(168,85,247,0.16)] backdrop-blur-[2px]">
    <div class="space-y-8">
        <div class="flex flex-wrap items-center gap-4">
            <p class="text-[0.7rem] uppercase tracking-[0.35em] text-fuchsia-200/85">Manager dashboard</p>
            <StatusTag Text="Admin metrics" />
        </div>

        @if (_items.Count == 0)
        {
            <div class="rounded-[1.75rem] border border-fuchsia-400/15 bg-black/25 p-6 shadow-[0_0_30px_rgba(192,132,252,0.14)] backdrop-blur-xl">
                <p class="text-[0.7rem] uppercase tracking-[0.3em] text-fuchsia-200/85">Servers</p>
                <h1 class="mt-3 text-3xl font-semibold tracking-tight text-white">No servers yet</h1>
                <p class="mt-4 max-w-3xl text-sm leading-7 text-neutral-300">
                    Accepted remote nodes will show their host metrics here.
                </p>
            </div>
        }
        else
        {
            <div class="grid gap-6 lg:grid-cols-2">
                @foreach (DashboardServerItem item in _items)
                {
                    <article class="rounded-[1.75rem] border border-fuchsia-400/15 bg-black/25 p-6 shadow-[0_0_30px_rgba(192,132,252,0.14)] backdrop-blur-xl">
                        <div class="flex items-start justify-between gap-4">
                            <div class="min-w-0">
                                <p class="truncate text-2xl font-semibold tracking-tight text-white">@item.ServerName</p>
                                <p class="mt-2 text-sm text-neutral-300">@item.VpnAddress</p>
                            </div>
                            <StatusTag Text="@item.ConnectionState" />
                        </div>

                        <div class="mt-6 grid gap-4">
                            <div class="rounded-[1.35rem] border border-white/10 bg-white/5 p-4">
                                <p class="text-[0.68rem] uppercase tracking-[0.28em] text-fuchsia-200/80">CPU</p>
                                <div class="mt-3 flex items-end justify-between gap-4">
                                    <div>
                                        <p class="text-xs uppercase tracking-[0.2em] text-neutral-400">Total</p>
                                        <p class="mt-1 text-sm font-semibold text-white">@item.CpuTotal</p>
                                    </div>
                                    <div class="text-right">
                                        <p class="text-xs uppercase tracking-[0.2em] text-neutral-400">Usage</p>
                                        <p class="mt-1 text-lg font-semibold text-white">@item.CpuUsage</p>
                                    </div>
                                </div>
                            </div>

                            <div class="rounded-[1.35rem] border border-white/10 bg-white/5 p-4">
                                <p class="text-[0.68rem] uppercase tracking-[0.28em] text-fuchsia-200/80">RAM</p>
                                <div class="mt-3 flex items-end justify-between gap-4">
                                    <div>
                                        <p class="text-xs uppercase tracking-[0.2em] text-neutral-400">Used / Total</p>
                                        <p class="mt-1 text-sm font-semibold text-white">@item.RamUsed / @item.RamTotal</p>
                                    </div>
                                    <div class="text-right">
                                        <p class="text-xs uppercase tracking-[0.2em] text-neutral-400">Usage</p>
                                        <p class="mt-1 text-lg font-semibold text-white">@item.RamUsage</p>
                                    </div>
                                </div>
                            </div>

                            <div class="rounded-[1.35rem] border border-white/10 bg-white/5 p-4">
                                <p class="text-[0.68rem] uppercase tracking-[0.28em] text-fuchsia-200/80">Disk</p>
                                <div class="mt-3 flex items-end justify-between gap-4">
                                    <div>
                                        <p class="text-xs uppercase tracking-[0.2em] text-neutral-400">Used / Total</p>
                                        <p class="mt-1 text-sm font-semibold text-white">@item.DiskUsed / @item.DiskTotal</p>
                                    </div>
                                    <div class="text-right">
                                        <p class="text-xs uppercase tracking-[0.2em] text-neutral-400">Usage</p>
                                        <p class="mt-1 text-lg font-semibold text-white">@item.DiskUsage</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </div>
</section>

@code {
    private IReadOnlyList<DashboardServerItem> _items = Array.Empty<DashboardServerItem>();
    private bool _isDisposed;

    protected override async Task OnInitializedAsync()
    {
        RemoteServerAdminHubClientService.Changed += OnRemoteAdminMetricsChanged;
        RemoteServerInfoService.InfoUpdated += OnRemoteServerInfoUpdated;
        await RefreshAsync();
    }

    public void Dispose()
    {
        _isDisposed = true;
        RemoteServerAdminHubClientService.Changed -= OnRemoteAdminMetricsChanged;
        RemoteServerInfoService.InfoUpdated -= OnRemoteServerInfoUpdated;
    }

    private void OnRemoteAdminMetricsChanged(int remoteServerId)
    {
        _ = RefreshFromEventAsync();
    }

    private void OnRemoteServerInfoUpdated(int remoteServerId)
    {
        _ = RefreshFromEventAsync();
    }

    private async Task RefreshFromEventAsync()
    {
        if (_isDisposed)
        {
            return;
        }

        await RefreshAsync();

        if (_isDisposed)
        {
            return;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshAsync()
    {
        await RemoteServerAdminHubClientService.SynchronizeNowAsync();
        await RemoteServerInfoService.RefreshAllNowAsync();

        IReadOnlyList<asa_server_controller.Models.Servers.RemoteServerListItem> servers = await RemoteServerService.LoadAsync();
        _items = servers
            .Select(BuildItem)
            .ToList();
    }

    private DashboardServerItem BuildItem(asa_server_controller.Models.Servers.RemoteServerListItem server)
    {
        asa_server_controller.Models.Servers.RemoteAdminHostMetricsSnapshot metrics = RemoteServerAdminHubClientService.GetSnapshot(server.Id);
        asa_server_controller.Models.Servers.RemoteServerInfoResponse? info = RemoteServerInfoService.GetLatestInfo(server.Id);
        bool isConnected = string.Equals(metrics.ConnectionState, "Connected", StringComparison.Ordinal);

        return new DashboardServerItem(
            string.IsNullOrWhiteSpace(server.ServerName) ? $"Server {server.Id}" : server.ServerName,
            server.VpnAddress,
            metrics.ConnectionState,
            isConnected ? FormatCpuTotal(info?.CpuCount) : "Waiting...",
            isConnected ? metrics.CpuUsage : "-",
            isConnected ? metrics.RamUsed : "-",
            isConnected ? (info?.TotalRam ?? "-") : "-",
            isConnected ? metrics.RamUsage : "-",
            isConnected ? metrics.DiskUsed : "-",
            isConnected ? (info?.DiskTotal ?? "-") : "-",
            isConnected ? metrics.DiskUsage : "-");
    }

    private static string FormatCpuTotal(int? cpuCount)
    {
        if (!cpuCount.HasValue || cpuCount.Value <= 0)
        {
            return "-";
        }

        return cpuCount.Value == 1 ? "1 core" : $"{cpuCount.Value} cores";
    }

    private sealed record DashboardServerItem(
        string ServerName,
        string VpnAddress,
        string ConnectionState,
        string CpuTotal,
        string CpuUsage,
        string RamUsed,
        string RamTotal,
        string RamUsage,
        string DiskUsed,
        string DiskTotal,
        string DiskUsage);
}
