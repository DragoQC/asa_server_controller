    private void ApplyNfsConfigurationToEditor()
    {
        _nfsServerConfigContent = _nfsConfiguration?.ServerConfigContent ?? string.Empty;
        _nfsClientConfigContent = _nfsConfiguration?.ClientConfigContent ?? string.Empty;
    }

    private void ResetModel()
    {
        VpnConfigModel defaults = VpnService.CreateDefaultModel();
        _fieldErrors.Clear();
        _model.PrivateKey = null;
        _model.Address = defaults.Address;
        _model.ListenPort = defaults.ListenPort;
        _model.PresharedKey = null;
        _model.Endpoint = null;
        _model.AllowedIps = defaults.AllowedIps;
        _model.PersistentKeepalive = defaults.PersistentKeepalive;
    }

    private async Task CopyServerPublicKeyAsync()
    {
        if (string.IsNullOrWhiteSpace(_serverKeys?.PublicKey))
        {
            return;
        }

        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _serverKeys.PublicKey);
        _statusMessage = "Server public key copied.";
        _statusIsError = false;
    }

    private bool ValidateFields()
    {
        AddRequiredFieldError(nameof(VpnConfigModel.PrivateKey), _model.PrivateKey, "Private key is required.");
        AddRequiredFieldError(nameof(VpnConfigModel.Address), _model.Address, "Address is required.");
        AddRequiredFieldError(nameof(VpnConfigModel.ListenPort), _model.ListenPort, "Listen port is required.");
        AddRequiredFieldError(nameof(VpnConfigModel.Endpoint), _model.Endpoint, "Endpoint is required.");
        AddRequiredFieldError(nameof(VpnConfigModel.AllowedIps), _model.AllowedIps, "Allowed IPs is required.");
        return _fieldErrors.Count == 0;
    }

    private void AddRequiredFieldError(string fieldName, string? value, string message)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            _fieldErrors[fieldName] = message;
        }
    }

    private bool IsSaveFieldsDisabled()
    {
        return _isSavingFields ||
            string.IsNullOrWhiteSpace(_model.PrivateKey) ||
            string.IsNullOrWhiteSpace(_model.Address) ||
            string.IsNullOrWhiteSpace(_model.ListenPort) ||
            string.IsNullOrWhiteSpace(_model.Endpoint) ||
            string.IsNullOrWhiteSpace(_model.AllowedIps);
    }

    private string? GetFieldError(string fieldName)
    {
        return _fieldErrors.GetValueOrDefault(fieldName);
    }

    private string GetStatusMessageClass()
    {
        return _statusIsError
            ? "rounded-2xl border border-red-300/20 bg-red-400/10 px-5 py-4 text-sm text-red-100"
            : "rounded-2xl border border-emerald-300/20 bg-emerald-400/10 px-5 py-4 text-sm text-emerald-100";
    }

    private string GetEditorMessageClass()
    {
        return _editorMessageIsError
            ? "mx-6 mt-6 rounded-2xl border border-red-300/20 bg-red-400/10 px-5 py-4 text-sm text-red-100"
            : "mx-6 mt-6 rounded-2xl border border-emerald-300/20 bg-emerald-400/10 px-5 py-4 text-sm text-emerald-100";
    }

    private string GetNfsConfigurationStateLabel()
    {
        if (_nfsConfiguration is null)
        {
            return "Not configured";
        }

        if (!_nfsConfiguration.ClusterFolderExists)
        {
            return "Missing folder";
        }

        if (_nfsConfiguration.ServerConfigExists && _nfsConfiguration.ClientConfigExists)
        {
            return "Ready";
        }

        return "Not configured";
    }

