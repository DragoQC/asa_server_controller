    private void ShowServerKeysDialog()
    {
        if (_serverKeys?.Exists != true)
        {
            return;
        }

        _generatedKeysEyebrow = "Server keys";
        _generatedKeysTitle = "Server keys";
        _generatedKeysMessage = "These are the current server keys used by the control node. The private key stays on the control server. Remote peers use the public key.";
        _generatedPrivateKey = _serverKeys.PrivateKey!;
        _generatedPublicKey = _serverKeys.PublicKey!;
        _showGeneratedKeysDialog = true;
    }

    private void CloseEditor()
    {
        _isEditorOpen = false;
        _editorContent = string.Empty;
        _editorMessage = null;
        _editorMessageIsError = false;
    }

    private async Task SaveFieldsAsync()
    {
        if (_file is null)
        {
            return;
        }

        _isSavingFields = true;
        _statusMessage = null;
        _statusIsError = false;
        _fieldErrors.Clear();

        try
        {
            if (!ValidateFields())
            {
                _statusMessage = "Please fill the required VPN fields.";
                _statusIsError = true;
                return;
            }

            string content = await VpnService.BuildContentAsync(_model);
            await VpnService.SaveSettingsAsync(new VpnServerSettingsModel
            {
                Endpoint = _model.Endpoint,
                AllowedIps = _model.AllowedIps,
                PersistentKeepalive = _model.PersistentKeepalive,
                PresharedKey = _model.PresharedKey
            });
            await VpnService.SaveAsync(_file.FilePath, content);
            await NfsService.SyncDefaultConfigIfExistsAsync();
            await InvitationService.RebuildServerConfigAsync();
            await ApplySavedConfigAsync($"{_file.Title} saved.");
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
            _statusIsError = true;
        }
        finally
        {
            _isSavingFields = false;
        }
    }

    private async Task SaveEditorAsync()
    {
        if (_file is null)
        {
            return;
        }

        _isSavingEditor = true;

        try
        {
            await VpnService.SaveAsync(_file.FilePath, _editorContent);
            await NfsService.SyncDefaultConfigIfExistsAsync();
            await InvitationService.RebuildServerConfigAsync();
            await ApplySavedConfigAsync(savedMessage: $"{_file.Title} saved.");
        }
        catch (Exception exception)
        {
            _editorMessage = exception.Message;
            _editorMessageIsError = true;
        }
        finally
        {
            _isSavingEditor = false;
        }
    }

    private async Task ApplySavedConfigAsync(string savedMessage)
    {
        try
        {
            await VpnService.EnableVpnAsync();

            if (_isVpnActive)
            {
                string restartMessage = await VpnService.RestartVpnAsync();
                _statusMessage = $"{savedMessage} {restartMessage}";
            }
            else
            {
                string startMessage = await VpnService.StartVpnAsync();
                _statusMessage = $"{savedMessage} {startMessage}";
            }

            _statusIsError = false;
            _editorMessage = _statusMessage;
            _editorMessageIsError = false;
            await RefreshAsync();
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
            _statusIsError = true;
            _editorMessage = exception.Message;
            _editorMessageIsError = true;
        }
    }

