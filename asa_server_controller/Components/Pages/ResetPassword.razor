@page "/admin/reset-password"
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject asa_server_controller.Services.AuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Reset Password</PageTitle>

<section class="rounded-b-[2rem] border-x border-b border-fuchsia-300/15 bg-gradient-to-br from-black/35 via-[#0b0612]/30 to-[#17081f]/35 p-8 shadow-[0_0_70px_rgba(168,85,247,0.14)] backdrop-blur-[2px]">
    <div class="space-y-8">
        <div class="flex flex-wrap items-center gap-4">
            <p class="text-xs font-semibold uppercase tracking-[0.45em] text-fuchsia-300">Account</p>
            <span class="rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100">
                @(_firstLogin ? "Password change required" : "Reset password")
            </span>
        </div>

        <div>
            <h1 class="text-4xl font-semibold tracking-tight text-white">Reset password</h1>
            <p class="mt-4 max-w-3xl text-base leading-7 text-neutral-300">
                @(_firstLogin
                    ? "The default admin password is still active. Set a new password before using the dashboard."
                    : "Set a new password for this manager account.")
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <div class="rounded-2xl border border-fuchsia-300/20 bg-fuchsia-400/10 px-5 py-4 text-sm text-fuchsia-100">
                @_message
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="rounded-2xl border border-red-300/20 bg-red-400/10 px-5 py-4 text-sm text-red-100">
                @_error
            </div>
        }

        <EditForm Model="_model" OnValidSubmit="SaveAsync" FormName="reset-password" class="max-w-2xl space-y-5">
            <DataAnnotationsValidator />

            <div>
                <label for="new-password" class="mb-2 block text-sm font-medium text-neutral-300">New password</label>
                <InputText id="new-password"
                           @bind-Value="_model.Password"
                           type="password"
                           autocomplete="new-password"
                           class="w-full rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-white outline-none" />
            </div>

            <div>
                <label for="confirm-password" class="mb-2 block text-sm font-medium text-neutral-300">Confirm password</label>
                <InputText id="confirm-password"
                           @bind-Value="_model.ConfirmPassword"
                           type="password"
                           autocomplete="new-password"
                           class="w-full rounded-2xl border border-white/10 bg-black/20 px-4 py-3 text-white outline-none" />
            </div>

            <button type="submit" class="inline-flex rounded-full border border-fuchsia-300/30 bg-fuchsia-400/15 px-5 py-2.5 text-sm font-medium text-fuchsia-100 transition hover:bg-fuchsia-400/25">
                Save password
            </button>
        </EditForm>
    </div>
</section>

@code {
    private readonly PasswordChangeModel _model = new();
    private string? _message;
    private string? _error;

    [SupplyParameterFromQuery]
    private bool _firstLogin { get; set; }

    private async Task SaveAsync()
    {
        _message = null;
        _error = null;

        if (string.IsNullOrWhiteSpace(_model.Password) || string.IsNullOrWhiteSpace(_model.ConfirmPassword))
        {
            _error = "Both password fields are required.";
            return;
        }

        if (!string.Equals(_model.Password, _model.ConfirmPassword, StringComparison.Ordinal))
        {
            _error = "Passwords do not match.";
            return;
        }

        AuthenticationState authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        Microsoft.AspNetCore.Identity.IdentityResult result = await AuthService.ChangePasswordAsync(authenticationState.User, _model.Password);
        if (!result.Succeeded)
        {
            _error = string.Join(' ', result.Errors.Select(error => error.Description));
            return;
        }

        _message = "Password updated.";
        NavigationManager.NavigateTo("/", forceLoad: true);
    }

    private sealed class PasswordChangeModel
    {
        public string? Password { get; set; }

        public string? ConfirmPassword { get; set; }
    }
}
