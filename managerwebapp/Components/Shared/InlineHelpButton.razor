<button type="button"
        @onclick="OnClick"
        class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 text-[0.7rem] font-semibold text-fuchsia-100 transition hover:bg-fuchsia-400/20"
        aria-label="@Label">
    ?
</button>

@code {
    [Parameter]
    public string Label { get; set; } = "Open help";

    [Parameter, EditorRequired]
    public EventCallback OnClick { get; set; }
}
