@inherits LayoutComponentBase

<div class="relative grid min-h-screen grid-rows-[auto_minmax(0,1fr)_auto] overflow-hidden bg-transparent text-neutral-100">
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
        <div class="absolute -left-32 -top-40 h-72 w-72 rounded-full bg-fuchsia-400/20 blur-3xl"></div>
        <div class="absolute -right-24 top-20 h-80 w-80 rounded-full bg-violet-400/15 blur-3xl"></div>
        <div class="absolute -bottom-40 left-1/3 h-96 w-96 rounded-full bg-pink-400/12 blur-3xl"></div>
    </div>

    <NavMenu />

    <main class="relative mx-auto flex min-h-0 w-full max-w-7xl flex-col px-6 pb-10 lg:px-8">
        <article class="flex-1">
            @Body
        </article>
    </main>

    <footer class="relative z-10 border-t border-white/10 bg-black/20">
        <div class="mx-auto flex max-w-7xl flex-col gap-3 px-6 py-5 text-sm text-neutral-400 lg:flex-row lg:items-center lg:justify-between lg:px-8">
            <p>Global neon control surface for ASA fleets.</p>
            <p class="flex flex-wrap items-center gap-x-3 gap-y-2 text-fuchsia-100/70">
                <span>Original panel made by Alex / DragoQC</span>
                <a href="https://github.com/DragoQC"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="transition hover:text-fuchsia-100">
                    GitHub
                </a>
                <a href="https://github.com/DragoQC/ASA_Server_Manager_Control"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="transition hover:text-fuchsia-100">
                    ASA Server Manager Control repo
                </a>
            </p>
        </div>
    </footer>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
