@page "/vpn"
@inject managerwebapp.Services.SudoService SudoService
@inject managerwebapp.Services.VpnConfigService VpnConfigService
@inject IJSRuntime JS
@using managerwebapp.Constants
@using managerwebapp.Models.Vpn

<PageTitle>VPN</PageTitle>

<section class="rounded-b-[2rem] border-x border-b border-fuchsia-400/15 bg-gradient-to-br from-black/35 via-[#0b0612]/30 to-[#17081f]/35 p-8 shadow-[0_0_48px_rgba(168,85,247,0.16)] backdrop-blur-[2px]">
    <div class="space-y-8">
        <div class="flex flex-wrap items-center justify-between gap-4">
            <div class="flex flex-wrap items-center gap-4">
                <p class="text-[0.7rem] uppercase tracking-[0.35em] text-fuchsia-200/85">VPN</p>
                <span class="rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100">
                    Fields + file
                </span>
            </div>

            <div class="flex flex-wrap gap-3">
                @if (_isWireGuardInstalled)
                {
                    <button type="button"
                            @onclick="StartWireGuardAsync"
                            disabled="@(_isWireGuardCommandBusy || _isWireGuardActive)"
                            class="inline-flex rounded-full border border-fuchsia-300/30 bg-fuchsia-400/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100 shadow-[0_0_18px_rgba(168,85,247,0.3)] transition hover:bg-fuchsia-400/25 disabled:cursor-not-allowed disabled:opacity-60">
                        @(_isStartingWireGuard ? "Starting..." : "Activate VPN")
                    </button>

                    <button type="button"
                            @onclick="StopWireGuardAsync"
                            disabled="@(_isWireGuardCommandBusy || !_isWireGuardActive)"
                            class="inline-flex rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-neutral-200 transition hover:bg-white/10 disabled:cursor-not-allowed disabled:opacity-60">
                        @(_isStoppingWireGuard ? "Stopping..." : "Deactivate VPN")
                    </button>
                }

                <button type="button"
                        @onclick="RefreshAsync"
                        disabled="@_isRefreshingPage"
                        class="inline-flex rounded-full border border-fuchsia-300/30 bg-fuchsia-400/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100 shadow-[0_0_18px_rgba(168,85,247,0.3)] transition hover:bg-fuchsia-400/25 disabled:cursor-not-allowed disabled:opacity-60">
                    @(_isRefreshingPage ? "Refreshing..." : "Refresh")
                </button>
            </div>
        </div>

        <div>
            <h1 class="text-4xl font-semibold tracking-tight text-white">VPN</h1>
            <p class="mt-4 max-w-3xl text-sm leading-7 text-neutral-300">
                Manage the main WireGuard settings from fields, then open the raw file when you want full control over `wg0.conf`.
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <div class="@GetStatusMessageClass()">
                @_statusMessage
            </div>
        }

        @if (!_isWireGuardInstalled)
        {
            <section class="rounded-[1.6rem] border border-fuchsia-400/15 bg-black/40 p-6 shadow-[0_0_40px_rgba(168,85,247,0.1)] backdrop-blur-md">
                <div class="flex flex-col items-center justify-center gap-5 text-center">
                    <div class="space-y-3">
                        <h2 class="text-2xl font-semibold text-white">WireGuard not installed</h2>
                        <p class="mx-auto max-w-3xl text-sm leading-6 text-neutral-300">
                            Install WireGuard when you are ready. Once installed, this page will show the `wg0.conf` state and let you create, open, edit, and apply the config.
                        </p>
                    </div>

                    <button type="button"
                            @onclick="InstallWireGuardAsync"
                            disabled="@_isInstallingWireGuard"
                            class="inline-flex rounded-full border border-fuchsia-300/30 bg-fuchsia-400/15 px-5 py-2.5 text-sm font-medium text-fuchsia-100 transition hover:bg-fuchsia-400/25 disabled:cursor-not-allowed disabled:opacity-60">
                        @(_isInstallingWireGuard ? "Installing..." : "Install WireGuard")
                    </button>
                </div>
            </section>
        }
        else if (_file is not null)
        {
            <div class="grid gap-6 xl:grid-cols-[minmax(0,1.45fr)_24rem]">
                <section class="space-y-6 rounded-[1.8rem] border border-white/10 bg-black/20 p-6 backdrop-blur">
                    <div class="space-y-3">
                        <div class="flex flex-wrap items-center gap-3">
                            <h2 class="text-3xl font-semibold text-white">WireGuard fields</h2>
                            <span class="rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100">
                                @(_file.Exists ? "Loaded" : "New config")
                            </span>
                        </div>

                        <p class="max-w-3xl text-base leading-7 text-neutral-300">
                            Edit the most common WireGuard settings directly from fields. Use the full file dialog when you want to inspect or tweak the raw config.
                        </p>
                    </div>

                    <div class="rounded-[1.4rem] border border-fuchsia-400/15 bg-fuchsia-400/5 p-5">
                        <p class="text-xs font-semibold uppercase tracking-[0.28em] text-fuchsia-300">Suggested private range</p>
                        <p class="mt-3 text-sm leading-6 text-neutral-300">
                            A simple default for this kind of VPN is `10.10.10.x`. It is a private range, so it is safe to use in Canada too as long as it does not collide with another VPN or routed internal network you already use.
                        </p>
                    </div>

                    <div class="flex flex-wrap gap-3">
                        <button type="button"
                                @onclick="GenerateClientKeysAsync"
                                disabled="@_isGeneratingKeys"
                                class="inline-flex rounded-full border border-fuchsia-300/30 bg-fuchsia-400/15 px-5 py-2.5 text-sm font-medium text-fuchsia-100 transition hover:bg-fuchsia-400/25 disabled:cursor-not-allowed disabled:opacity-60">
                            @(_isGeneratingClientKeys ? "Generating client keys..." : "Generate client keys")
                        </button>

                        <button type="button"
                                @onclick="GenerateServerKeysAsync"
                                disabled="@_isGeneratingKeys"
                                class="inline-flex rounded-full border border-white/10 bg-white/5 px-5 py-2.5 text-sm font-medium text-neutral-200 transition hover:bg-white/10 disabled:cursor-not-allowed disabled:opacity-60">
                            @(_isGeneratingServerKeys ? "Generating server keys..." : "Generate server keys")
                        </button>
                    </div>

                    <div class="grid gap-4 md:grid-cols-2">
                        <div class="rounded-[1.4rem] border border-white/10 bg-white/5 p-5">
                            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-fuchsia-300">Client keys</p>
                            <p class="mt-3 text-sm leading-6 text-neutral-300">
                                @(_clientKeys?.Exists == true ? "Saved under the VPN folder for reuse and copy." : "No saved client key pair yet.")
                            </p>
                            <p class="mt-3 text-xs uppercase tracking-[0.2em] text-neutral-500">@VpnConstants.ClientPublicKeyFilePath</p>
                        </div>

                        <div class="rounded-[1.4rem] border border-white/10 bg-white/5 p-5">
                            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-fuchsia-300">Server keys</p>
                            <p class="mt-3 text-sm leading-6 text-neutral-300">
                                @(_serverKeys?.Exists == true ? "Saved under the VPN folder for reuse and copy." : "No saved server key pair yet.")
                            </p>
                            <p class="mt-3 text-xs uppercase tracking-[0.2em] text-neutral-500">@VpnConstants.ServerPublicKeyFilePath</p>
                        </div>
                    </div>

                    <div class="flex flex-wrap gap-3">
                        <button type="button"
                                @onclick="CopyClientPublicKeyAsync"
                                disabled="@string.IsNullOrWhiteSpace(_clientKeys?.PublicKey)"
                                class="inline-flex rounded-full border border-white/10 bg-white/5 px-5 py-2.5 text-sm font-medium text-neutral-200 transition hover:bg-white/10 disabled:cursor-not-allowed disabled:opacity-60">
                            Copy client public key
                        </button>

                        <button type="button"
                                @onclick="CopyServerPublicKeyAsync"
                                disabled="@string.IsNullOrWhiteSpace(_serverKeys?.PublicKey)"
                                class="inline-flex rounded-full border border-white/10 bg-white/5 px-5 py-2.5 text-sm font-medium text-neutral-200 transition hover:bg-white/10 disabled:cursor-not-allowed disabled:opacity-60">
                            Copy server public key
                        </button>
                    </div>

                    <div class="grid gap-4 md:grid-cols-2">
                        <TextHelpField Label="Private key"
                                       @bind-Value="_model.PrivateKey"
                                       OnHelpClick="@(() => OpenHelpDialog(
                                           "Private key",
                                           "This is the private key for the local [Interface]. Keep it secret and do not share it. Use client key generation for this field on a client config."))"
                                       HelpButtonLabel="Private key help"
                                       autocomplete="off"
                                       placeholder="Base64 private key"
                                       Hint="Use `Generate client keys` to create one and fill this field automatically." />
                        <TextHelpField Label="Address"
                                       @bind-Value="_model.Address"
                                       OnHelpClick="@(() => OpenHelpDialog(
                                           "Address",
                                           "This is the VPN IP/subnet assigned to this node. Pick a private range that is not already used on your LAN or another routed VPN. Good examples are 10.10.10.2/32 for one client or 10.10.10.1/24 for a server subnet."))"
                                       HelpButtonLabel="Address help"
                                       autocomplete="off"
                                       placeholder="10.10.10.2/32"
                                       Hint="Prefilled in UI with 10.10.10.2/32 until the file contains something else." />
                        <TextHelpField Label="Listen port"
                                       @bind-Value="_model.ListenPort"
                                       OnHelpClick="@(() => OpenHelpDialog(
                                           "Listen port",
                                           "UDP port WireGuard listens on. 51820 is the common default. This is usually required for a server config and often optional for a simple client config."))"
                                       HelpButtonLabel="Listen port help"
                                       autocomplete="off"
                                       placeholder="51820"
                                       Hint="Prefilled in UI with 51820 until the file contains something else." />
                        <TextHelpField Label="DNS"
                                       @bind-Value="_model.Dns"
                                       OnHelpClick="@(() => OpenHelpDialog(
                                           "DNS",
                                           "DNS server used while the tunnel is up. This can be a public resolver like 1.1.1.1 or an internal DNS server reachable through the VPN."))"
                                       HelpButtonLabel="DNS help"
                                       autocomplete="off"
                                       placeholder="1.1.1.1"
                                       Hint="Common values: 1.1.1.1, 8.8.8.8, or your own internal DNS." />
                        <TextHelpField Label="Peer public key"
                                       @bind-Value="_model.PeerPublicKey"
                                       OnHelpClick="@(() => OpenHelpDialog(
                                           "Peer public key",
                                           "This is the public key of the remote peer. On a client config, this is usually the server public key. The server private key stays on the server and must not be pasted here."))"
                                       HelpButtonLabel="Peer public key help"
                                       autocomplete="off"
                                       placeholder="Base64 peer public key"
                                       Hint="Use `Generate server keys` to create a fresh server pair and fill this field with the server public key." />
                        <TextHelpField Label="Preshared key"
                                       @bind-Value="_model.PresharedKey"
                                       OnHelpClick="@(() => OpenHelpDialog(
                                           "Preshared key",
                                           "Optional extra shared secret used by both sides. If you use one, the exact same key must be configured on the remote peer too."))"
                                       HelpButtonLabel="Preshared key help"
                                       autocomplete="off"
                                       placeholder="Optional preshared key" />
                        <TextHelpField Label="Endpoint"
                                       @bind-Value="_model.Endpoint"
                                       OnHelpClick="@(() => OpenHelpDialog(
                                           "Endpoint",
                                           "Public host or IP and UDP port of the remote WireGuard server, for example vpn.example.com:51820 or 203.0.113.10:51820."))"
                                       HelpButtonLabel="Endpoint help"
                                       autocomplete="off"
                                       placeholder="control.example.com:51820" />
                        <TextHelpField Label="Allowed IPs"
                                       @bind-Value="_model.AllowedIps"
                                       OnHelpClick="@(() => OpenHelpDialog(
                                           "Allowed IPs",
                                           "Defines which traffic should go through the VPN tunnel for this peer. For a VPN-only subnet use something like 10.10.10.0/24. For a full tunnel use 0.0.0.0/0 and ::/0."))"
                                       HelpButtonLabel="Allowed IPs help"
                                       autocomplete="off"
                                       placeholder="10.10.10.0/24"
                                       Hint="Prefilled in UI with 10.10.10.0/24 until the file contains something else." />
                        <div class="md:col-span-2">
                            <TextHelpField Label="Persistent keepalive"
                                           @bind-Value="_model.PersistentKeepalive"
                                           OnHelpClick="@(() => OpenHelpDialog(
                                               "Persistent keepalive",
                                               "Useful for clients behind NAT. 25 seconds is the usual value. Leave it empty if you do not need it."))"
                                           HelpButtonLabel="Persistent keepalive help"
                                           autocomplete="off"
                                           placeholder="25"
                                           Hint="Prefilled in UI with 25 until the file contains something else." />
                        </div>
                    </div>

                    <div class="flex flex-wrap gap-3">
                        <button type="button"
                                @onclick="SaveFieldsAsync"
                                disabled="@_isSavingFields"
                                class="inline-flex rounded-full border border-fuchsia-300/30 bg-fuchsia-400/15 px-5 py-2.5 text-sm font-medium text-fuchsia-100 transition hover:bg-fuchsia-400/25 disabled:cursor-not-allowed disabled:opacity-60">
                            @(_isSavingFields ? "Saving..." : "Save")
                        </button>

                        <button type="button"
                                @onclick="OpenEditorAsync"
                                class="inline-flex rounded-full border border-white/10 bg-white/5 px-5 py-2.5 text-sm font-medium text-neutral-200 transition hover:bg-white/10">
                            Open file
                        </button>
                    </div>
                </section>

                <aside class="space-y-4 rounded-[1.8rem] border border-white/10 bg-black/20 p-6 backdrop-blur">
                    <div class="rounded-[1.4rem] border border-white/10 bg-white/5 p-5">
                        <p class="text-xs font-semibold uppercase tracking-[0.28em] text-fuchsia-300">Config state</p>
                        <div class="mt-4 flex flex-wrap gap-2">
                            <span class="rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100">
                                @_file.StateLabel
                            </span>
                            <span class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-neutral-200">
                                @(_isWireGuardActive ? "Active" : "Inactive")
                            </span>
                        </div>
                        <p class="mt-4 text-sm leading-6 text-neutral-300">
                            @_file.Description
                        </p>
                    </div>

                    <div class="rounded-[1.4rem] border border-white/10 bg-white/5 p-5">
                        <p class="text-xs font-semibold uppercase tracking-[0.28em] text-fuchsia-300">File path</p>
                        <p class="mt-3 text-sm leading-6 text-neutral-300">
                            <code class="rounded bg-white/10 px-2 py-1 text-neutral-200">@_file.FilePath</code>
                        </p>
                    </div>

                    <div class="rounded-[1.4rem] border border-white/10 bg-white/5 p-5">
                        <div class="flex flex-wrap items-center justify-between gap-3">
                            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-fuchsia-300">Service status</p>
                            <button type="button"
                                    @onclick="RefreshWireGuardStatusAsync"
                                    disabled="@_isRefreshingStatus"
                                    class="inline-flex rounded-full border border-white/10 bg-white/5 px-3 py-1.5 text-[0.65rem] font-semibold uppercase tracking-[0.2em] text-neutral-200 transition hover:bg-white/10 disabled:cursor-not-allowed disabled:opacity-60">
                                @(_isRefreshingStatus ? "Loading..." : "Refresh status")
                            </button>
                        </div>

                        <pre class="mt-4 overflow-x-auto whitespace-pre-wrap rounded-[1.2rem] border border-white/10 bg-black/35 px-4 py-3 font-mono text-xs leading-6 text-neutral-200">@_wireGuardStatusOutput</pre>
                    </div>
                </aside>
            </div>
        }
    </div>
</section>

@if (_file is not null && _isEditorOpen)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/55 p-6 backdrop-blur-sm">
        <div class="flex h-[min(88vh,72rem)] w-full max-w-6xl flex-col rounded-[1.8rem] border border-fuchsia-400/15 bg-[#05070d]/92 shadow-[0_0_80px_rgba(168,85,247,0.18)] backdrop-blur-xl">
            <div class="flex flex-wrap items-start justify-between gap-4 border-b border-white/10 px-6 py-5">
                <div class="space-y-2">
                    <div class="flex flex-wrap items-center gap-3">
                        <h2 class="text-3xl font-semibold text-white">@_file.Title</h2>
                        <span class="rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100">
                            @_file.StateLabel
                        </span>
                    </div>
                    <p class="max-w-3xl text-sm leading-6 text-neutral-300">@_file.Description</p>
                    <p class="text-xs uppercase tracking-[0.28em] text-neutral-500">@_file.FilePath</p>
                </div>

                <div class="flex flex-wrap gap-3">
                    <button type="button"
                            @onclick="SaveEditorAsync"
                            disabled="@_isSavingEditor"
                            class="inline-flex rounded-full border border-fuchsia-300/30 bg-fuchsia-400/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100 shadow-[0_0_18px_rgba(168,85,247,0.3)] transition hover:bg-fuchsia-400/25 disabled:cursor-not-allowed disabled:opacity-60">
                        @(_isSavingEditor ? "Saving..." : "Save")
                    </button>
                    <button type="button"
                            @onclick="CloseEditor"
                            class="inline-flex rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-neutral-200 transition hover:bg-white/10">
                        Cancel
                    </button>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_editorMessage))
            {
                <div class="@GetEditorMessageClass()">
                    @_editorMessage
                </div>
            }

            <div class="flex-1 p-6">
                <textarea @bind="_editorContent"
                          @bind:event="oninput"
                          spellcheck="false"
                          class="h-full min-h-[32rem] w-full rounded-[1.3rem] border border-white/10 bg-black/40 p-4 font-mono text-sm leading-6 text-fuchsia-100 outline-none"></textarea>
            </div>
        </div>
    </div>
}

<ConfirmationDialog IsOpen="@_showRestartDialog"
                    IsBusy="@_isRestartingWireGuard"
                    Eyebrow="Restart"
                    Title="Restart WireGuard now?"
                    Message="The config file was saved. WireGuard is currently active, so the new config will not be applied until `wg-quick@wg0` is restarted."
                    ConfirmText="Restart now"
                    CancelText="I'll do it later"
                    OnConfirm="RestartWireGuardAsync"
                    OnCancel="SkipRestartAsync" />

<InfoDialog IsOpen="@_showHelpDialog"
            Eyebrow="Field help"
            Title="@_helpDialogTitle"
            Message="@_helpDialogMessage"
            OnClose="CloseHelpDialog" />

<InfoDialog IsOpen="@_showGeneratedKeysDialog"
            Eyebrow="@_generatedKeysEyebrow"
            Title="@_generatedKeysTitle"
            OnClose="CloseGeneratedKeysDialog">
    <p>@_generatedKeysMessage</p>

    <div class="space-y-3">
        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-fuchsia-300">Private key</p>
            <pre class="mt-2 overflow-x-auto rounded-2xl border border-white/10 bg-black/35 px-4 py-3 font-mono text-xs leading-6 text-fuchsia-100">@_generatedPrivateKey</pre>
        </div>

        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-fuchsia-300">Public key</p>
            <pre class="mt-2 overflow-x-auto rounded-2xl border border-white/10 bg-black/35 px-4 py-3 font-mono text-xs leading-6 text-fuchsia-100">@_generatedPublicKey</pre>
        </div>
    </div>
</InfoDialog>

@code {
    private readonly VpnConfigModel _model = new();
    private VpnConfigFileState? _file;
    private string _editorContent = string.Empty;
    private string? _statusMessage;
    private bool _statusIsError;
    private string? _editorMessage;
    private bool _editorMessageIsError;
    private bool _isInstallingWireGuard;
    private bool _isRestartingWireGuard;
    private bool _isSavingFields;
    private bool _isSavingEditor;
    private bool _isGeneratingClientKeys;
    private bool _isGeneratingServerKeys;
    private bool _isStartingWireGuard;
    private bool _isStoppingWireGuard;
    private bool _isRefreshingStatus;
    private bool _isRefreshingPage;
    private bool _isEditorOpen;
    private bool _isWireGuardActive;
    private bool _isWireGuardInstalled;
    private bool _showRestartDialog;
    private bool _showHelpDialog;
    private bool _showGeneratedKeysDialog;
    private string _helpDialogTitle = string.Empty;
    private string _helpDialogMessage = string.Empty;
    private string _generatedKeysEyebrow = "Keys";
    private string _generatedKeysTitle = string.Empty;
    private string _generatedKeysMessage = string.Empty;
    private string _generatedPrivateKey = string.Empty;
    private string _generatedPublicKey = string.Empty;
    private SavedVpnKeyPair? _clientKeys;
    private SavedVpnKeyPair? _serverKeys;
    private string _wireGuardStatusOutput = "WireGuard status not loaded yet.";
    private string? _postSaveMessage;
    private bool _isGeneratingKeys => _isGeneratingClientKeys || _isGeneratingServerKeys;
    private bool _isWireGuardCommandBusy => _isStartingWireGuard || _isStoppingWireGuard || _isRestartingWireGuard;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        _isRefreshingPage = true;

        try
        {
            _isWireGuardInstalled = await VpnConfigService.IsWireGuardInstalledAsync();
            _isWireGuardActive = _isWireGuardInstalled && await SudoService.IsWireGuardActiveAsync();

            if (_isWireGuardInstalled)
            {
                _file = await VpnConfigService.LoadStateAsync();
                await ReloadModelFromFileAsync();
                await ReloadSavedKeysAsync();
                await RefreshWireGuardStatusAsync();
            }
            else
            {
                _file = null;
                ResetModel();
                _clientKeys = null;
                _serverKeys = null;
                _wireGuardStatusOutput = "WireGuard is not installed.";
            }
        }
        finally
        {
            _isRefreshingPage = false;
        }
    }

    private async Task InstallWireGuardAsync()
    {
        _isInstallingWireGuard = true;
        _statusMessage = null;
        _statusIsError = false;

        try
        {
            if (_isWireGuardInstalled)
            {
                _statusMessage = "WireGuard is already installed.";
            }
            else
            {
                _statusMessage = await SudoService.InstallWireGuardAsync();
            }
            _statusIsError = false;
            await RefreshAsync();
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
            _statusIsError = true;
        }
        finally
        {
            _isInstallingWireGuard = false;
        }
    }

    private async Task OpenEditorAsync()
    {
        if (_file is null)
        {
            return;
        }

        try
        {
            _editorContent = await VpnConfigService.LoadEditorContentAsync(_file.FilePath);
            _editorMessage = null;
            _editorMessageIsError = false;
            _statusMessage = null;
            _statusIsError = false;
            _isEditorOpen = true;
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
            _statusIsError = true;
        }
    }

    private async Task GenerateClientKeysAsync()
    {
        _isGeneratingClientKeys = true;
        _statusMessage = null;
        _statusIsError = false;

        try
        {
            SavedVpnKeyPair keyPair = await VpnConfigService.GenerateAndSaveClientKeyPairAsync();
            _model.PrivateKey = keyPair.PrivateKey;
            _clientKeys = keyPair;
            _generatedKeysEyebrow = "Client keys";
            _generatedKeysTitle = "Client keys generated";
            _generatedKeysMessage = "The client private key was inserted into the `Private key` field. Keep that private key secret. The public key is shown for reference if you need to register the client on the server side.";
            _generatedPrivateKey = keyPair.PrivateKey ?? string.Empty;
            _generatedPublicKey = keyPair.PublicKey ?? string.Empty;
            _showGeneratedKeysDialog = true;
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
            _statusIsError = true;
        }
        finally
        {
            _isGeneratingClientKeys = false;
        }
    }

    private async Task GenerateServerKeysAsync()
    {
        _isGeneratingServerKeys = true;
        _statusMessage = null;
        _statusIsError = false;

        try
        {
            SavedVpnKeyPair keyPair = await VpnConfigService.GenerateAndSaveServerKeyPairAsync();
            _model.PeerPublicKey = keyPair.PublicKey;
            _serverKeys = keyPair;
            _generatedKeysEyebrow = "Server keys";
            _generatedKeysTitle = "Server keys generated";
            _generatedKeysMessage = "The server public key was inserted into the `Peer public key` field. The server private key shown below belongs on the server side only and should not be pasted into this client peer field.";
            _generatedPrivateKey = keyPair.PrivateKey ?? string.Empty;
            _generatedPublicKey = keyPair.PublicKey ?? string.Empty;
            _showGeneratedKeysDialog = true;
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
            _statusIsError = true;
        }
        finally
        {
            _isGeneratingServerKeys = false;
        }
    }

    private void CloseEditor()
    {
        _isEditorOpen = false;
        _editorContent = string.Empty;
        _editorMessage = null;
        _editorMessageIsError = false;
    }

    private async Task SaveFieldsAsync()
    {
        if (_file is null)
        {
            return;
        }

        _isSavingFields = true;
        _statusMessage = null;
        _statusIsError = false;
        bool wasWireGuardActive = _isWireGuardActive;

        try
        {
            string content = await VpnConfigService.BuildContentAsync(_model);
            await VpnConfigService.SaveAsync(_file.FilePath, content);
            _postSaveMessage = $"{_file.Title} saved.";
            await RefreshAsync();
            await HandlePostSaveAsync(wasWireGuardActive);
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
            _statusIsError = true;
        }
        finally
        {
            _isSavingFields = false;
        }
    }

    private async Task SaveEditorAsync()
    {
        if (_file is null)
        {
            return;
        }

        _isSavingEditor = true;
        bool wasWireGuardActive = _isWireGuardActive;

        try
        {
            await VpnConfigService.SaveAsync(_file.FilePath, _editorContent);
            _postSaveMessage = $"{_file.Title} saved.";
            await RefreshAsync();
            await HandlePostSaveAsync(wasWireGuardActive);
        }
        catch (Exception exception)
        {
            _editorMessage = exception.Message;
            _editorMessageIsError = true;
        }
        finally
        {
            _isSavingEditor = false;
        }
    }

    private Task HandlePostSaveAsync(bool wasWireGuardActive)
    {
        if (wasWireGuardActive)
        {
            _showRestartDialog = true;
            return Task.CompletedTask;
        }

        _statusMessage = _postSaveMessage ?? "Config saved.";
        _statusIsError = false;
        _editorMessage = _statusMessage;
        _editorMessageIsError = false;
        _postSaveMessage = null;
        return Task.CompletedTask;
    }

    private async Task RestartWireGuardAsync()
    {
        _isRestartingWireGuard = true;

        try
        {
            await SudoService.RestartWireGuardAsync();
            _showRestartDialog = false;
            _statusMessage = $"{_postSaveMessage ?? "Config saved."} {VpnConstants.WireGuardServiceName} restarted.";
            _statusIsError = false;
            _editorMessage = _statusMessage;
            _editorMessageIsError = false;
            _postSaveMessage = null;
            await RefreshAsync();
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
            _statusIsError = true;
            _editorMessage = exception.Message;
            _editorMessageIsError = true;
        }
        finally
        {
            _isRestartingWireGuard = false;
        }
    }

    private async Task StartWireGuardAsync()
    {
        _isStartingWireGuard = true;
        _statusMessage = null;
        _statusIsError = false;

        try
        {
            await SudoService.StartWireGuardAsync();
            _statusMessage = $"{VpnConstants.WireGuardServiceName} started.";
            _statusIsError = false;
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
            _statusIsError = true;
        }
        finally
        {
            _isStartingWireGuard = false;
            await RefreshAsync();
        }
    }

    private async Task StopWireGuardAsync()
    {
        _isStoppingWireGuard = true;
        _statusMessage = null;
        _statusIsError = false;

        try
        {
            await SudoService.StopWireGuardAsync();
            _statusMessage = $"{VpnConstants.WireGuardServiceName} stopped.";
            _statusIsError = false;
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
            _statusIsError = true;
        }
        finally
        {
            _isStoppingWireGuard = false;
            await RefreshAsync();
        }
    }

    private Task SkipRestartAsync()
    {
        _showRestartDialog = false;
        _statusMessage = $"{_postSaveMessage ?? "Config saved."} Restart {VpnConstants.WireGuardServiceName} later to apply the new config.";
        _statusIsError = false;
        _editorMessage = _statusMessage;
        _editorMessageIsError = false;
        _postSaveMessage = null;
        return Task.CompletedTask;
    }

    private async Task ReloadModelFromFileAsync()
    {
        VpnConfigModel loadedModel = await VpnConfigService.LoadModelAsync();
        _model.PrivateKey = loadedModel.PrivateKey;
        _model.Address = loadedModel.Address;
        _model.ListenPort = loadedModel.ListenPort;
        _model.Dns = loadedModel.Dns;
        _model.PeerPublicKey = loadedModel.PeerPublicKey;
        _model.PresharedKey = loadedModel.PresharedKey;
        _model.Endpoint = loadedModel.Endpoint;
        _model.AllowedIps = loadedModel.AllowedIps;
        _model.PersistentKeepalive = loadedModel.PersistentKeepalive;
    }

    private async Task RefreshWireGuardStatusAsync()
    {
        _isRefreshingStatus = true;

        try
        {
            _wireGuardStatusOutput = _isWireGuardInstalled
                ? await SudoService.GetWireGuardStatusAsync()
                : "WireGuard is not installed.";
        }
        catch (Exception exception)
        {
            _wireGuardStatusOutput = exception.Message;
        }
        finally
        {
            _isRefreshingStatus = false;
        }
    }

    private async Task ReloadSavedKeysAsync()
    {
        _clientKeys = await VpnConfigService.LoadClientKeyPairAsync();
        _serverKeys = await VpnConfigService.LoadServerKeyPairAsync();
    }

    private void ResetModel()
    {
        VpnConfigModel defaults = VpnConfigService.CreateDefaultModel();
        _model.PrivateKey = null;
        _model.Address = defaults.Address;
        _model.ListenPort = defaults.ListenPort;
        _model.Dns = null;
        _model.PeerPublicKey = null;
        _model.PresharedKey = null;
        _model.Endpoint = null;
        _model.AllowedIps = defaults.AllowedIps;
        _model.PersistentKeepalive = defaults.PersistentKeepalive;
    }

    private async Task CopyClientPublicKeyAsync()
    {
        if (string.IsNullOrWhiteSpace(_clientKeys?.PublicKey))
        {
            return;
        }

        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _clientKeys.PublicKey);
        _statusMessage = "Client public key copied.";
        _statusIsError = false;
    }

    private async Task CopyServerPublicKeyAsync()
    {
        if (string.IsNullOrWhiteSpace(_serverKeys?.PublicKey))
        {
            return;
        }

        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _serverKeys.PublicKey);
        _statusMessage = "Server public key copied.";
        _statusIsError = false;
    }

    private string GetStatusMessageClass()
    {
        return _statusIsError
            ? "rounded-2xl border border-red-300/20 bg-red-400/10 px-5 py-4 text-sm text-red-100"
            : "rounded-2xl border border-emerald-300/20 bg-emerald-400/10 px-5 py-4 text-sm text-emerald-100";
    }

    private string GetEditorMessageClass()
    {
        return _editorMessageIsError
            ? "mx-6 mt-6 rounded-2xl border border-red-300/20 bg-red-400/10 px-5 py-4 text-sm text-red-100"
            : "mx-6 mt-6 rounded-2xl border border-emerald-300/20 bg-emerald-400/10 px-5 py-4 text-sm text-emerald-100";
    }

    private void OpenHelpDialog(string title, string message)
    {
        _helpDialogTitle = title;
        _helpDialogMessage = message;
        _showHelpDialog = true;
    }

    private Task CloseHelpDialog()
    {
        _showHelpDialog = false;
        return Task.CompletedTask;
    }

    private Task CloseGeneratedKeysDialog()
    {
        _showGeneratedKeysDialog = false;
        return Task.CompletedTask;
    }
}
