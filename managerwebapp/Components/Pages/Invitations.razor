@page "/admin/invitations"
@inject managerwebapp.Services.InvitationService InvitationService
@inject IJSRuntime JS

<PageTitle>Invitations</PageTitle>

<section class="rounded-b-[2rem] border-x border-b border-fuchsia-400/15 bg-gradient-to-br from-black/35 via-[#0b0612]/30 to-[#17081f]/35 p-8 shadow-[0_0_48px_rgba(168,85,247,0.16)] backdrop-blur-[2px]">
    <div class="space-y-8">
        <div class="flex flex-wrap items-center gap-4">
            <p class="text-[0.7rem] uppercase tracking-[0.35em] text-fuchsia-200/85">Invitations</p>
            <span class="rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100">
                Remote join flow
            </span>
        </div>

        <div>
            <h1 class="text-4xl font-semibold tracking-tight text-white">Invitations</h1>
            <p class="mt-4 max-w-3xl text-sm leading-7 text-neutral-300">
                Create one-time VPN invitation links for future remote servers, keep a history of previous invitations, and track which invited machines come online on the VPN.
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <div class="@GetStatusMessageClass()">
                @_statusMessage
            </div>
        }

        <section class="rounded-[1.8rem] border border-white/10 bg-black/20 p-6 backdrop-blur">
            <div class="space-y-3">
                <h2 class="text-2xl font-semibold text-white">Create invitation link</h2>
                <p class="max-w-3xl text-sm leading-6 text-neutral-300">
                    Generate a single invite link for one node. The VPN address is assigned here, the cluster ID comes from Cluster setup, and the control app pregenerates that node's WireGuard files before the link is used.
                </p>
            </div>

            <div class="mt-6 grid gap-4 md:grid-cols-2">
                <TextField Label="VPN address"
                           @bind-Value="_form.VpnAddress"
                           placeholder="10.10.10.3/32"
                           Hint="Prefilled from current VPN setup. Adjust only if you need another address."
                           autocomplete="off" />

                <TextField Label="Cluster ID"
                           @bind-Value="_form.ClusterId"
                           readonly="readonly"
                           placeholder="Set from Cluster setup"
                           Hint="Managed from the Cluster setup page. Invitations are blocked until a cluster ID is configured."
                           autocomplete="off" />
            </div>

            <div class="mt-6 flex flex-wrap gap-3">
                <button type="button"
                        @onclick="CreateInvitationLinkAsync"
                        disabled="@_isSending"
                        class="inline-flex rounded-full border border-fuchsia-300/30 bg-fuchsia-400/15 px-5 py-2.5 text-sm font-medium text-fuchsia-100 transition hover:bg-fuchsia-400/25 disabled:cursor-not-allowed disabled:opacity-60">
                    @(_isSending ? "Creating..." : "Create invitation link")
                </button>

                <button type="button"
                        @onclick="RefreshAsync"
                        disabled="@_isRefreshing"
                        class="inline-flex rounded-full border border-white/10 bg-white/5 px-5 py-2.5 text-sm font-medium text-neutral-200 transition hover:bg-white/10 disabled:cursor-not-allowed disabled:opacity-60">
                    @(_isRefreshing ? "Refreshing..." : "Refresh")
                </button>
            </div>

            @if (_previewPayload is not null)
            {
                <div class="mt-6 space-y-4 rounded-[1.6rem] border border-white/10 bg-black/25 p-5">
                    <div class="flex flex-wrap items-center justify-between gap-3">
                        <div>
                            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-fuchsia-300">Invite link</p>
                            <p class="mt-2 break-all text-sm text-neutral-300">@(string.IsNullOrWhiteSpace(_lastCreatedInviteLink) ? "Create an invite to get a one-time link." : _lastCreatedInviteLink)</p>
                        </div>
                        <button type="button"
                                @onclick="CopyInviteLinkAsync"
                                disabled="@string.IsNullOrWhiteSpace(_lastCreatedInviteLink)"
                                class="inline-flex rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-neutral-200 transition hover:bg-white/10 disabled:cursor-not-allowed disabled:opacity-60">
                            Copy link
                        </button>
                    </div>

                    <div>
                        <p class="text-xs font-semibold uppercase tracking-[0.28em] text-fuchsia-300">Payload preview</p>
                        <pre class="mt-4 overflow-x-auto whitespace-pre-wrap rounded-[1.2rem] border border-white/10 bg-black/35 px-4 py-3 font-mono text-xs leading-6 text-neutral-200">@BuildPayloadPreview()</pre>
                    </div>

                    <div>
                        <p class="text-xs font-semibold uppercase tracking-[0.28em] text-fuchsia-300">Invitation wg0.conf preview</p>
                        <pre class="mt-4 overflow-x-auto whitespace-pre-wrap rounded-[1.2rem] border border-white/10 bg-black/35 px-4 py-3 font-mono text-xs leading-6 text-neutral-200">@_previewPayload.Wg0Config</pre>
                    </div>
                </div>
            }
        </section>

        <section class="space-y-4">
            <div class="flex flex-wrap items-center justify-between gap-3">
                <h2 class="text-2xl font-semibold text-white">Previous invitations</h2>
                <span class="rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100">
                    @_items.Count invitation(s)
                </span>
            </div>

            @if (_items.Count == 0)
            {
                <div class="rounded-[1.6rem] border border-white/10 bg-black/20 p-6 text-sm leading-6 text-neutral-300">
                    No invitations yet.
                </div>
            }
            else
            {
                <div class="space-y-4">
                    @foreach (managerwebapp.Models.Invitations.InvitationListItem item in _items)
                    {
                        <div class="rounded-[1.6rem] border border-white/10 bg-black/20 p-6 backdrop-blur">
                            <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
                                <div class="space-y-3">
                                    <div class="flex flex-wrap gap-2">
                                        <span class="rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100">
                                            @item.InviteStatus
                                        </span>
                                        <span class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-neutral-200">
                                            @item.ValidationStatus
                                        </span>
                                    </div>

                                    <div>
                                        <p class="text-sm font-medium text-white">@(string.IsNullOrWhiteSpace(item.RemoteUrl) ? "Link-based invitation" : item.RemoteUrl)</p>
                                        <p class="mt-1 text-sm text-neutral-300">Cluster ID: @item.ClusterId</p>
                                        <p class="mt-1 text-sm text-neutral-300">VPN address: @item.VpnAddress</p>
                                        <p class="mt-1 break-all text-sm text-neutral-300">Invite link: @item.InviteLink</p>
                                        <button type="button"
                                                @onclick="() => OpenInvitationConfigAsync(item.Id)"
                                                class="mt-3 inline-flex rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-neutral-200 transition hover:bg-white/10">
                                            View wg0.conf
                                        </button>
                                    </div>
                                </div>

                                <div class="text-sm text-neutral-400">
                                    <p>Created: @item.CreatedAtUtc.LocalDateTime</p>
                                    <p>Used: @(item.UsedAtUtc?.LocalDateTime.ToString() ?? "Not used")</p>
                                    <p>Last seen: @(item.LastSeenAtUtc?.LocalDateTime.ToString() ?? "Never")</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>
    </div>
</section>

@code {
    private readonly managerwebapp.Models.Invitations.InvitationFormModel _form = new();
    private IReadOnlyList<managerwebapp.Models.Invitations.InvitationListItem> _items = Array.Empty<managerwebapp.Models.Invitations.InvitationListItem>();
    private managerwebapp.Models.Invitations.InviteRemoteServerRequest? _previewPayload;
    private string? _lastCreatedInviteLink;
    private string? _selectedInvitationConfig;
    private string _selectedInvitationConfigTitle = string.Empty;
    private string? _statusMessage;
    private bool _statusIsError;
    private bool _isRefreshing;
    private bool _isSending;
    private bool _isInvitationConfigDialogOpen;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        _isRefreshing = true;

        try
        {
            managerwebapp.Models.Invitations.InvitationFormModel defaults = await InvitationService.CreateDefaultFormAsync();
            _form.ClusterId = defaults.ClusterId;
            _form.VpnAddress = defaults.VpnAddress;
            _previewPayload = await InvitationService.BuildPreviewAsync(_form);
            _items = await InvitationService.LoadAsync();
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
            _statusIsError = true;
        }
        finally
        {
            _isRefreshing = false;
        }
    }

    private async Task CreateInvitationLinkAsync()
    {
        _isSending = true;
        _statusMessage = null;
        _statusIsError = false;

        try
        {
            managerwebapp.Models.Invitations.InvitationListItem item = await InvitationService.CreateInvitationLinkAsync(_form);
            _statusMessage = $"Invitation link created. Share {item.InviteLink}";
            _statusIsError = false;
            _lastCreatedInviteLink = item.InviteLink;
            await RefreshAsync();
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
            _statusIsError = true;
        }
        finally
        {
            _isSending = false;
        }
    }

    private async Task OpenInvitationConfigAsync(int invitationId)
    {
        try
        {
            _selectedInvitationConfig = await InvitationService.LoadInvitationConfigAsync(invitationId);
            _selectedInvitationConfigTitle = $"Invitation {invitationId} wg0.conf";
            _isInvitationConfigDialogOpen = true;
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
            _statusIsError = true;
        }
    }

    private Task CloseInvitationConfigDialog()
    {
        _isInvitationConfigDialogOpen = false;
        _selectedInvitationConfig = null;
        _selectedInvitationConfigTitle = string.Empty;
        return Task.CompletedTask;
    }

    private string GetStatusMessageClass()
    {
        return _statusIsError
            ? "rounded-2xl border border-red-300/20 bg-red-400/10 px-5 py-4 text-sm text-red-100"
            : "rounded-2xl border border-emerald-300/20 bg-emerald-400/10 px-5 py-4 text-sm text-emerald-100";
    }

    private async Task CopyInviteLinkAsync()
    {
        if (string.IsNullOrWhiteSpace(_lastCreatedInviteLink))
        {
            return;
        }

        await JS.InvokeVoidAsync("navigator.clipboard.writeText", _lastCreatedInviteLink);
        _statusMessage = "Invite link copied.";
        _statusIsError = false;
    }

    private string BuildPayloadPreview()
    {
        if (_previewPayload is null)
        {
            return "No payload preview available.";
        }

        return string.Join(
            "\n",
            $"ClusterId: {_previewPayload.ClusterId}",
            $"VpnAddress: {_previewPayload.VpnAddress}",
            $"ServerEndpoint: {_previewPayload.ServerEndpoint}",
            $"AllowedIps: {_previewPayload.AllowedIps}",
            $"RemoteApiKey: {_previewPayload.RemoteApiKey}",
            $"ServerPublicKey: {_previewPayload.ServerPublicKey}",
            $"ClientPrivateKey: {_previewPayload.ClientPrivateKey}",
            $"Wg0Config: generated",
            $"PresharedKey: {(_previewPayload.PresharedKey ?? "(none)")}");
    }

}

<InfoDialog IsOpen="@_isInvitationConfigDialogOpen"
            Eyebrow="Invitation file"
            Title="@_selectedInvitationConfigTitle"
            OnClose="@CloseInvitationConfigDialog">
    <pre class="overflow-x-auto whitespace-pre-wrap rounded-[1.2rem] border border-white/10 bg-black/35 px-4 py-3 font-mono text-xs leading-6 text-fuchsia-100">@(_selectedInvitationConfig ?? "No invitation config loaded.")</pre>
</InfoDialog>
