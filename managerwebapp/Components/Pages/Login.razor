@page "/admin/login"
@layout AuthLayout
@inject managerwebapp.Services.AuthService AuthService

<PageTitle>Login</PageTitle>

<section class="w-full max-w-xl rounded-[2rem] border border-fuchsia-300/15 bg-black/25 p-5 shadow-[0_0_70px_rgba(168,85,247,0.14)] backdrop-blur-[2px]">
    <div class="space-y-5">
        <div class="flex flex-wrap items-center gap-4">
            <p class="text-xs font-semibold uppercase tracking-[0.45em] text-fuchsia-300">Connection</p>
            <span class="rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100">
                Login required
            </span>
        </div>

        <div>
            <h1 class="text-4xl font-semibold tracking-tight text-white">Connect to the manager</h1>
            @if (_showDefaultAdminAutofill)
            {
                <p class="mt-3 max-w-2xl text-sm leading-6 text-neutral-300">
                    Sign in to unlock the panel. Default first access is <code class="rounded bg-white/10 px-2 py-1 text-neutral-100">admin</code> / <code class="rounded bg-white/10 px-2 py-1 text-neutral-100">admin</code>.
                </p>
            }
            else
            {
                <p class="mt-3 max-w-2xl text-sm leading-6 text-neutral-300">
                    Sign in to unlock the panel.
                </p>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(Error))
        {
            <div class="rounded-2xl border border-red-300/20 bg-red-400/10 px-5 py-4 text-sm text-red-100">
                @Error
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="rounded-2xl border border-fuchsia-300/20 bg-fuchsia-400/10 px-5 py-4 text-sm text-fuchsia-100">
                @Message
            </div>
        }

        <form method="post" action="/auth/login" data-enhance="false" @formname="login" class="space-y-4">
            <div>
                <label for="username" class="mb-2 block text-sm font-medium text-neutral-300">Username or email</label>
                <input id="username"
                       name="username"
                       @bind="_username"
                       autocomplete="username"
                       class="w-full rounded-2xl border border-white/10 bg-black/20 px-4 py-2.5 text-white outline-none" />
            </div>

            <section class="rounded-[1.8rem] border border-white/10 bg-black/20 p-3 backdrop-blur">
                <div class="grid grid-cols-3 gap-3 p-2">
                    <button type="button"
                            @onclick='() => SetLoginMethod("password")'
                            class="@GetTabClass("password")">
                        Password
                    </button>
                    <button type="button"
                            @onclick='() => SetLoginMethod("email")'
                            class="@GetTabClass("email")">
                        Email
                    </button>
                    <button type="button"
                            @onclick='() => SetLoginMethod("totp")'
                            class="@GetTabClass("totp")">
                        TOTP
                    </button>
                </div>

                <div class="mt-4 p-3">
                    @if (string.Equals(_activeLoginMethod, "password", StringComparison.Ordinal))
                    {
                        <div class="@GetPanelClass()">
                            <div class="space-y-3">
                                <div>
                                    <p class="text-xs font-semibold uppercase tracking-[0.35em] text-fuchsia-300">Password</p>
                                    <p class="mt-1 text-sm text-neutral-300">Sign in with your username or email and password.</p>
                                </div>

                                <div>
                                    <label for="password" class="mb-1.5 block text-sm font-medium text-neutral-300">Password</label>
                                    <input id="password"
                                           name="password"
                                           type="password"
                                           @bind="_password"
                                           autocomplete="current-password"
                                           class="w-full rounded-2xl border border-white/10 bg-black/20 px-4 py-2.5 text-white outline-none" />
                                </div>

                                <button type="submit"
                                        name="action"
                                        value="password"
                                        class="inline-flex rounded-full border border-fuchsia-300/30 bg-fuchsia-400/15 px-5 py-2.5 text-sm font-medium text-fuchsia-100 transition hover:bg-fuchsia-400/25">
                                    Login with password
                                </button>
                            </div>
                        </div>
                    }
                    else if (string.Equals(_activeLoginMethod, "email", StringComparison.Ordinal))
                    {
                        <div class="@GetPanelClass()">
                            <div class="space-y-3">
                                <div>
                                    <p class="text-xs font-semibold uppercase tracking-[0.35em] text-fuchsia-300">Email code</p>
                                    <p class="mt-1 text-sm text-neutral-300">Request a one-time code by email, then enter it here.</p>
                                </div>

                                <div class="flex flex-wrap gap-3">
                                    <button type="submit"
                                            name="action"
                                            value="email-request"
                                            class="inline-flex rounded-full border border-fuchsia-300/30 bg-fuchsia-400/15 px-5 py-2.5 text-sm font-medium text-fuchsia-100 transition hover:bg-fuchsia-400/25">
                                        Send email code
                                    </button>
                                </div>

                                <div>
                                    <label for="emailCode" class="mb-1.5 block text-sm font-medium text-neutral-300">Email code</label>
                                    <input id="emailCode"
                                           name="emailCode"
                                           @bind="_emailCode"
                                           autocomplete="one-time-code"
                                           inputmode="numeric"
                                           class="w-full rounded-2xl border border-white/10 bg-black/20 px-4 py-2.5 text-white outline-none" />
                                </div>

                                <button type="submit"
                                        name="action"
                                        value="email"
                                        class="inline-flex rounded-full border border-fuchsia-300/30 bg-fuchsia-400/15 px-5 py-2.5 text-sm font-medium text-fuchsia-100 transition hover:bg-fuchsia-400/25">
                                    Login with email code
                                </button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="@GetPanelClass()">
                            <div class="space-y-3">
                                <div>
                                    <p class="text-xs font-semibold uppercase tracking-[0.35em] text-fuchsia-300">TOTP</p>
                                    <p class="mt-1 text-sm text-neutral-300">Use the 6-digit code from Google Authenticator, Bitwarden, or another TOTP app.</p>
                                </div>

                                <div>
                                    <label for="twoFactorCode" class="mb-1.5 block text-sm font-medium text-neutral-300">2FA code</label>
                                    <input id="twoFactorCode"
                                           name="twoFactorCode"
                                           @bind="_twoFactorCode"
                                           autocomplete="one-time-code"
                                           inputmode="numeric"
                                           class="w-full rounded-2xl border border-white/10 bg-black/20 px-4 py-2.5 text-white outline-none" />
                                </div>

                                <button type="submit"
                                        name="action"
                                        value="totp"
                                        class="inline-flex rounded-full border border-fuchsia-300/30 bg-fuchsia-400/15 px-5 py-2.5 text-sm font-medium text-fuchsia-100 transition hover:bg-fuchsia-400/25">
                                    Login with 2FA
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </section>
        </form>
    </div>
</section>

@code {
    private bool _showDefaultAdminAutofill;
    private string _username = string.Empty;
    private string _password = string.Empty;
    private string _emailCode = string.Empty;
    private string _twoFactorCode = string.Empty;
    private string _activeLoginMethod = "password";

    [SupplyParameterFromQuery]
    private string? Error { get; set; }

    [SupplyParameterFromQuery]
    private string? Message { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _showDefaultAdminAutofill = await AuthService.MustChangePasswordAsync("admin");

        if (_showDefaultAdminAutofill)
        {
            _username = "admin";
            _password = "admin";
        }
    }

    private void SetLoginMethod(string method)
    {
        _activeLoginMethod = method;

        switch (method)
        {
            case "password":
                _emailCode = string.Empty;
                _twoFactorCode = string.Empty;
                break;
            case "email":
                _password = string.Empty;
                _twoFactorCode = string.Empty;
                break;
            case "totp":
                _password = string.Empty;
                _emailCode = string.Empty;
                break;
        }
    }

    private string GetTabClass(string method)
    {
        return string.Equals(_activeLoginMethod, method, StringComparison.Ordinal)
            ? "inline-flex items-center justify-center rounded-full border border-fuchsia-300/30 bg-fuchsia-400/15 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100 shadow-[0_0_18px_rgba(168,85,247,0.3)] transition hover:bg-fuchsia-400/25"
            : "inline-flex items-center justify-center rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-neutral-200 transition hover:bg-white/10";
    }

    private static string GetPanelClass()
    {
        return "opacity-100 translate-x-0 transform transition duration-300";
    }
}
