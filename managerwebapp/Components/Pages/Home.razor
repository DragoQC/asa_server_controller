@page "/"
@inject managerwebapp.Services.RemoteServerModsService RemoteServerModsService
@inject managerwebapp.Services.RemoteServerHubClientService RemoteServerHubClientService
@inject managerwebapp.Services.RemoteServerInfoService RemoteServerInfoService
@inject managerwebapp.Services.InvitationEventsService InvitationEventsService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>ASA Fleet</PageTitle>

<section class="rounded-b-[2rem] border-x border-b border-fuchsia-400/15 bg-gradient-to-br from-black/35 via-[#0b0612]/30 to-[#17081f]/35 p-8 shadow-[0_0_48px_rgba(168,85,247,0.16)] backdrop-blur-[2px]">
    <div class="space-y-8">
        <div class="flex flex-wrap items-center justify-between gap-4">
            <div>
                <p class="text-[0.7rem] uppercase tracking-[0.35em] text-fuchsia-200/85">Public fleet overview</p>
                <h1 class="mt-3 text-4xl font-semibold tracking-tight text-white">Remote ASA servers</h1>
                <p class="mt-4 max-w-3xl text-sm leading-7 text-neutral-300">
                    Public status page for the ASA fleet. Open a server card to see the current players and the locally cached mod catalog for that node.
                </p>
            </div>
        </div>

        @if (_servers.Count == 0)
        {
            <div class="rounded-[1.75rem] border border-fuchsia-400/15 bg-black/25 p-6 shadow-[0_0_30px_rgba(192,132,252,0.14)] backdrop-blur-xl">
                <p class="text-[0.7rem] uppercase tracking-[0.3em] text-fuchsia-200/85">Fleet</p>
                <p class="mt-3 text-2xl font-semibold text-white">No accepted servers yet</p>
                <p class="mt-2 text-sm text-neutral-300">No public server entries yet. Once a remote node accepts an invite, it will appear here.</p>
            </div>
        }
        else
        {
            <div class="flex flex-wrap gap-5">
                @foreach (managerwebapp.Models.Home.HomeServerModel server in _servers)
                {
                    <button type="button"
                            @onclick="() => OpenServerDialog(server)"
                            class="flex min-h-64 w-full flex-col justify-between rounded-[1.75rem] border border-fuchsia-400/15 bg-black/25 p-6 text-left shadow-[0_0_30px_rgba(192,132,252,0.14)] backdrop-blur-xl transition hover:border-fuchsia-300/25 hover:bg-black/30 sm:w-[calc(50%-0.625rem)] lg:w-[calc(33.333%-0.875rem)] xl:w-[calc(25%-0.9375rem)]">
                        <div class="space-y-5">
                            <div class="flex flex-wrap gap-2">
                                <StatusTag Text="@server.StateLabel" />
                            </div>

                            <div>
                                <h2 class="text-2xl font-semibold leading-tight text-white">@server.DisplayServerName</h2>
                                <p class="mt-2 text-sm text-fuchsia-200/80">@server.FormattedMapName</p>
                            </div>
                        </div>

                        <div class="space-y-3 pt-6">
                            <div class="flex items-center justify-between gap-4 text-sm text-neutral-300">
                                <span>Players</span>
                                <span class="font-semibold text-white">@server.CurrentPlayers / @server.MaxPlayers</span>
                            </div>
                            <div class="flex items-center justify-between gap-4 text-sm text-neutral-300">
                                <span>Mods</span>
                                <span class="font-semibold text-white">@server.Mods.Count</span>
                            </div>
                        </div>
                    </button>
                }
            </div>
        }
    </div>
</section>

@if (_selectedServer is not null)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/55 p-6 backdrop-blur-sm">
        <div class="max-h-[90vh] w-full max-w-7xl overflow-y-auto rounded-[1.8rem] border border-fuchsia-400/15 bg-[#05070d]/94 p-6 shadow-[0_0_80px_rgba(168,85,247,0.18)] backdrop-blur-xl">
            <div class="space-y-6">
                <div class="flex items-start justify-between gap-4">
                    <div class="space-y-3">
                        <div class="flex flex-wrap gap-2">
                            <StatusTag Text="@_selectedServer.StateLabel" />
                        </div>

                        <div>
                            <h2 class="text-3xl font-semibold text-white">@_selectedServer.DisplayServerName</h2>
                            <p class="mt-2 text-base text-fuchsia-200/80">@_selectedServer.FormattedMapName</p>
                        </div>
                    </div>

                    <ActionButton Text="Close"
                                  Secondary="true"
                                  OnClick="CloseServerDialog" />
                </div>

                <section class="rounded-[1.6rem] border border-white/10 bg-black/20 p-5">
                    <div class="flex flex-wrap gap-6">
                        <div class="min-w-40">
                            <p class="text-[0.65rem] uppercase tracking-[0.24em] text-fuchsia-200/70">Players</p>
                            <p class="mt-2 text-lg font-semibold text-white">@_selectedServer.CurrentPlayers / @_selectedServer.MaxPlayers</p>
                        </div>
                        <div class="min-w-40">
                            <p class="text-[0.65rem] uppercase tracking-[0.24em] text-fuchsia-200/70">Mods</p>
                            <p class="mt-2 text-lg font-semibold text-white">@_selectedServer.Mods.Count</p>
                        </div>
                    </div>
                </section>

                @if (_selectedServer.Mods.Count == 0)
                {
                    <p class="text-sm text-neutral-300">No mods cached for this server yet.</p>
                }
                else
                {
                    <div class="grid grid-cols-1 items-start gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
                        @foreach (managerwebapp.Models.Servers.PublicServerModItem mod in _selectedServer.Mods)
                        {
                            <button type="button"
                                    @onclick="() => OpenModPage(mod.WebsiteUrl)"
                                    disabled="@string.IsNullOrWhiteSpace(mod.WebsiteUrl)"
                                    class="group h-fit w-full overflow-hidden rounded-[1.6rem] border border-fuchsia-200/12 bg-black/40 text-left align-top shadow-[0_0_40px_rgba(168,85,247,0.08)] backdrop-blur-md transition hover:border-fuchsia-300/20 hover:bg-black/45 disabled:cursor-default">
                                <div class="relative aspect-square w-full shrink-0 overflow-hidden border-b border-fuchsia-200/10 bg-gradient-to-br from-fuchsia-400/15 via-[#07121d] to-violet-400/10">
                                    @if (!string.IsNullOrWhiteSpace(mod.LogoUrl))
                                    {
                                        <img src="@mod.LogoUrl" alt="@mod.Name" class="h-full w-full object-contain p-4 opacity-95 transition duration-300 group-hover:scale-[1.03]" />
                                        <div class="absolute inset-0 bg-gradient-to-t from-[#05070d] via-[#05070d]/20 to-transparent"></div>
                                    }
                                </div>

                                <div class="space-y-3 p-4">
                                    <h3 class="text-base font-semibold leading-6 text-white break-words">@mod.Name</h3>
                                    <p class="text-xs font-semibold uppercase tracking-[0.22em] text-fuchsia-200/75 break-all">@mod.ModId</p>
                                    <p class="text-sm leading-6 text-neutral-300 break-words">@mod.Summary</p>
                                </div>
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private IReadOnlyList<managerwebapp.Models.Home.HomeServerModel> _servers = [];
    private managerwebapp.Models.Home.HomeServerModel? _selectedServer;
    private bool _isRefreshing;
    private bool _isDisposed;

    protected override async Task OnInitializedAsync()
    {
        RemoteServerHubClientService.StatusUpdated += OnRemoteStatusUpdatedAsync;
        RemoteServerHubClientService.SnapshotUpdated += OnRemoteSnapshotUpdatedAsync;
        RemoteServerInfoService.InfoUpdated += OnRemoteInfoUpdatedAsync;
        InvitationEventsService.Changed += OnInvitationChangedAsync;
        await RefreshAsync();
    }

    public void Dispose()
    {
        _isDisposed = true;
        RemoteServerHubClientService.StatusUpdated -= OnRemoteStatusUpdatedAsync;
        RemoteServerHubClientService.SnapshotUpdated -= OnRemoteSnapshotUpdatedAsync;
        RemoteServerInfoService.InfoUpdated -= OnRemoteInfoUpdatedAsync;
        InvitationEventsService.Changed -= OnInvitationChangedAsync;
    }

    private async Task RefreshAsync()
    {
        if (_isDisposed)
        {
            return;
        }

        _isRefreshing = true;

        try
        {
            managerwebapp.Models.Home.HomePageModel model = await RemoteServerModsService.LoadHomeModelAsync();
            _servers = model.Servers;
            if (_selectedServer is not null)
            {
                _selectedServer = _servers.FirstOrDefault(server => server.RemoteServerId == _selectedServer.RemoteServerId);
            }
        }
        finally
        {
            _isRefreshing = false;
        }
    }

    private Task OnRemoteStatusUpdatedAsync(int _, managerwebapp.Models.Servers.RemoteAsaServiceStatus __)
    {
        return RefreshFromEventAsync();
    }

    private Task OnRemoteSnapshotUpdatedAsync(int _)
    {
        return RefreshFromEventAsync();
    }

    private Task OnRemoteInfoUpdatedAsync(int _)
    {
        return RefreshFromEventAsync();
    }

    private Task OnInvitationChangedAsync()
    {
        return RefreshFromEventAsync();
    }

    private Task RefreshFromEventAsync()
    {
        if (_isDisposed)
        {
            return Task.CompletedTask;
        }

        return InvokeAsync(async () =>
        {
            if (_isDisposed || _isRefreshing)
            {
                return;
            }

            await RefreshAsync();
            StateHasChanged();
        });
    }

    private void OpenServerDialog(managerwebapp.Models.Home.HomeServerModel server)
    {
        _selectedServer = server;
    }

    private void CloseServerDialog()
    {
        _selectedServer = null;
    }

    private async Task OpenModPage(string? websiteUrl)
    {
        if (string.IsNullOrWhiteSpace(websiteUrl))
        {
            return;
        }

        await JS.InvokeVoidAsync("open", websiteUrl, "_blank", "noopener,noreferrer");
    }
}
