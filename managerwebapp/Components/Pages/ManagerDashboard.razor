@page "/admin/dashboard"

<PageTitle>Manager Dashboard</PageTitle>

<section class="rounded-b-[2rem] border-x border-b border-fuchsia-400/15 bg-gradient-to-br from-black/35 via-[#0b0612]/30 to-[#17081f]/35 p-8 shadow-[0_0_48px_rgba(168,85,247,0.16)] backdrop-blur-[2px]">
    <div class="space-y-8">
        <div class="flex flex-wrap items-center gap-4">
            <p class="text-[0.7rem] uppercase tracking-[0.35em] text-fuchsia-200/85">Manager dashboard</p>
            <span class="rounded-full border border-fuchsia-300/20 bg-fuchsia-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100">
                Admin only
            </span>
        </div>

        <div>
            <h1 class="text-4xl font-semibold tracking-tight text-white">Fleet command center</h1>
            <p class="mt-4 max-w-3xl text-sm leading-7 text-neutral-300">
                This is the internal manager dashboard. From here you can open server tools, VPN setup, invitations, CurseForge caching, and the local control settings.
            </p>
        </div>

        <div class="grid gap-4 lg:grid-cols-3">
            <div class="rounded-[1.75rem] border border-fuchsia-400/15 bg-black/25 p-6 shadow-[0_0_30px_rgba(192,132,252,0.14)] backdrop-blur-xl">
                <p class="text-[0.7rem] uppercase tracking-[0.3em] text-fuchsia-200/85">Servers</p>
                <p class="mt-3 text-2xl font-semibold text-white">Fleet registry</p>
                <p class="mt-2 text-sm text-neutral-300">Track accepted remote nodes, their VPN identity, and the connection state we keep for later actions.</p>
                <a href="/admin/servers" class="mt-4 inline-flex rounded-full border border-fuchsia-300/25 bg-fuchsia-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100 transition hover:bg-fuchsia-400/20">
                    Open Servers
                </a>
            </div>

            <div class="rounded-[1.75rem] border border-fuchsia-400/15 bg-black/25 p-6 shadow-[0_0_30px_rgba(192,132,252,0.14)] backdrop-blur-xl">
                <p class="text-[0.7rem] uppercase tracking-[0.3em] text-fuchsia-200/85">Cluster setup</p>
                <p class="mt-3 text-2xl font-semibold text-white">Cluster + WireGuard</p>
                <p class="mt-2 text-sm text-neutral-300">Manage the shared ARK cluster ID, the control node WireGuard config, key generation, activation state, and the raw file editor.</p>
                <a href="/admin/cluster" class="mt-4 inline-flex rounded-full border border-fuchsia-300/25 bg-fuchsia-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100 transition hover:bg-fuchsia-400/20">
                    Open Cluster setup
                </a>
            </div>

            <div class="rounded-[1.75rem] border border-fuchsia-400/15 bg-black/25 p-6 shadow-[0_0_30px_rgba(192,132,252,0.14)] backdrop-blur-xl">
                <p class="text-[0.7rem] uppercase tracking-[0.3em] text-fuchsia-200/85">Invitations</p>
                <p class="mt-3 text-2xl font-semibold text-white">Node onboarding</p>
                <p class="mt-2 text-sm text-neutral-300">Prepare remote VPN values, send invites to new nodes, and keep the accepted invitation history in the local database.</p>
                <a href="/admin/invitations" class="mt-4 inline-flex rounded-full border border-fuchsia-300/25 bg-fuchsia-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100 transition hover:bg-fuchsia-400/20">
                    Open Invitations
                </a>
            </div>

            <div class="rounded-[1.75rem] border border-fuchsia-400/15 bg-black/25 p-6 shadow-[0_0_30px_rgba(192,132,252,0.14)] backdrop-blur-xl">
                <p class="text-[0.7rem] uppercase tracking-[0.3em] text-fuchsia-200/85">CurseForge</p>
                <p class="mt-3 text-2xl font-semibold text-white">Mod metadata cache</p>
                <p class="mt-2 text-sm text-neutral-300">Store the API key, sync fleet mod ids, and cache the mod cards used by the public fleet overview.</p>
                <a href="/admin/curseforge" class="mt-4 inline-flex rounded-full border border-fuchsia-300/25 bg-fuchsia-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100 transition hover:bg-fuchsia-400/20">
                    Open CurseForge
                </a>
            </div>

            <div class="rounded-[1.75rem] border border-fuchsia-400/15 bg-black/25 p-6 shadow-[0_0_30px_rgba(192,132,252,0.14)] backdrop-blur-xl">
                <p class="text-[0.7rem] uppercase tracking-[0.3em] text-fuchsia-200/85">Settings</p>
                <p class="mt-3 text-2xl font-semibold text-white">Local control app</p>
                <p class="mt-2 text-sm text-neutral-300">Open local manager settings and hidden account actions like the password reset flow.</p>
                <a href="/admin/settings" class="mt-4 inline-flex rounded-full border border-fuchsia-300/25 bg-fuchsia-400/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-100 transition hover:bg-fuchsia-400/20">
                    Open Settings
                </a>
            </div>
        </div>
    </div>
</section>
